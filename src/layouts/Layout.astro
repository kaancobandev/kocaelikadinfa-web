---
import IntroLoader from '../components/IntroLoader.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = "Kocaeli Kadın Futbol Kulübü",
  description = "Kocaeli Kadın Futbol Kulübü resmi web sitesi. A Takım, Pilot Takım, akademi, maç sonuçları ve haberler. Kadın futbolunun Kocaeli'deki gücü.",
  image = "/logo.jpeg",
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site?.href ?? "https://kocaelikadinfa.com/";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL(image, siteUrl);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SportsOrganization",
  name: "Kocaeli Kadın Futbol Kulübü",
  alternateName: "Kocaeli Kadın FA",
  url: siteUrl,
  logo: new URL("/logo.jpeg", siteUrl).href,
  image: ogImage.href,
  description,
  sport: "Kadın Futbolu",
  email: "kocaelikadinfa@gmail.com",
  telephone: "+905326944509",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Kozluk",
    addressLocality: "İzmit",
    addressRegion: "Kocaeli",
    postalCode: "41200",
    addressCountry: "TR",
  },
  sameAs: [
    "https://www.instagram.com/kocaelikadinfa",
    "https://www.youtube.com/@kocaelikadinfa",
    "https://www.tiktok.com/@kocaelikadinfutbol",
    "https://x.com/kocaelikadnfa",
  ],
};
---
<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/logo.jpeg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta name="theme-color" content="#0d4d1e" />
    <meta name="author" content="Kocaeli Kadın Futbol Kulübü" />
    <meta name="geo.region" content="TR-41" />
    <meta name="geo.placename" content="Kocaeli" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Kocaeli Kadın Futbol Kulübü" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="tr_TR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <IntroLoader />
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black:        #000000;
    --dark:         #060806;
    --card-bg:      #0c100c;
    --green:        #0d4d1e;
    --green-mid:    #116025;
    --green-bright: #2cb84a;
    --green-glow:   rgba(13,77,30,0.35);
    --text:         #ffffff;
    --text-muted:   #7a7a7a;
    --border:       rgba(255,255,255,0.07);
    --radius:       12px;
    --nav-h:        70px;

    /* ── Görsel boyut sistemi ──────────────────────────────────────────
       Fotoğraflar kendi en-boy oranını korur; yalnızca bu sınırların
       dışına taşanlar kırpılır. Böylece aşırı uzun dikey fotoğraflar
       sayfayı ele geçirmez, aşırı geniş olanlar da şeride dönmez.     */
    --media-min-h:     170px;   /* çok geniş fotoğraflar için taban   */
    --media-max-h:     520px;   /* çok uzun fotoğraflar için tavan    */
    --media-max-h-sm:  380px;   /* tek kolona düşen dar ekranlarda    */
    --card-media-max-h: 440px;  /* sabit oranlı haber kartı görselleri */
  }

  /* Tüm görseller kapsayıcısını taşmasın */
  img { max-width: 100%; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--black);
    color: var(--text);
    line-height: 1.6;
  }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--dark); }
  ::-webkit-scrollbar-thumb { background: var(--green); border-radius: 3px; }

  .btn-primary {
    display: inline-block;
    background: var(--green);
    color: #fff;
    padding: .8rem 2rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: .9rem;
    letter-spacing: 1px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background .25s, transform .2s, box-shadow .2s;
  }
  .btn-primary:hover {
    background: var(--green-mid);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--green-glow);
  }

  .section-tag {
    display: inline-block;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--green-bright);
    margin-bottom: 1rem;
  }

  .reveal { opacity: 0; transform: translateY(24px); transition: opacity .6s ease, transform .6s ease; }
  .reveal.visible { opacity: 1; transform: none; }
</style>
