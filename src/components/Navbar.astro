---
const links = [
  { href: "/pilot-takim", label: "Pilot Takım" },
  { href: "/mac-gecmisi", label: "Maç Geçmişi" },
  { href: "/a-takim",     label: "A Takım" },
  { href: "/akademi",     label: "Akademi" },
  { href: "/haberler",              label: "Haberler" },
  { href: "/antrenmanlardan-kareler", label: "Galeri" },
];
---

<nav class="navbar" id="navbar">
  <a class="nav-logo" href="/">
    <img src="/logo.jpeg" alt="Kocaeli Kadın FA Logo" class="logo-img" />
    <span class="logo-text">
      <span class="logo-text-full">Kocaeli Kadın Futbol Kulübü</span>
      <span class="logo-text-short">Kocaeli Kadın FK</span>
    </span>
  </a>

  <button
    type="button"
    id="nav-toggle"
    class="nav-burger"
    aria-label="Menüyü aç"
    aria-expanded="false"
    aria-controls="nav-links"
  >
    <span></span><span></span><span></span>
  </button>

  <ul class="nav-links" id="nav-links">
    {links.map(l => (
      <li><a href={l.href}>{l.label}</a></li>
    ))}
    <li><a href="/aramiza-katil" class="btn-join">Aramıza Katıl</a></li>
  </ul>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    background: rgba(0,0,0,0.93);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 5%;
    z-index: 1000;
    transition: height .3s;
  }
  .navbar.scrolled { height: 58px; }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .logo-img { height: 42px; width: 42px; object-fit: contain; border-radius: 50%; }

  @media (max-width: 768px) {
    .nav-logo { padding: 8px 0; }
    .logo-img { height: 38px; width: 38px; }
  }
  .logo-text {
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: 3px;
    background: linear-gradient(135deg, #fff 0%, var(--green-bright) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .logo-text-short { display: none; }

  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    /* Gerçek buton: klavyeyle odaklanabilir ve Enter/Space ile açılır */
    background: none;
    border: none;
    padding: 10px 6px;
    margin: -10px -6px;
    border-radius: 6px;
  }
  .nav-burger span {
    display: block;
    width: 25px; height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: .3s;
  }
  .nav-burger:focus-visible {
    outline: 2px solid var(--green-bright);
    outline-offset: 2px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 2rem;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--text-muted);
    font-size: .85rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color .25s;
  }
  .nav-links a:hover { color: var(--green-bright); }

  .btn-join {
    background: var(--green) !important;
    color: #fff !important;
    padding: .5rem 1.2rem;
    border-radius: 50px;
    transition: background .25s, transform .2s !important;
  }
  .btn-join:hover { background: var(--green-mid) !important; transform: translateY(-1px); }

  @media (max-width: 768px) {
    /* Tek satırda kalması için kısa ad */
    .logo-text { font-size: .95rem; letter-spacing: 1px; white-space: nowrap; }
    .logo-text-full  { display: none; }
    .logo-text-short { display: inline; }

    .nav-burger { display: flex; }

    .nav-links {
      position: fixed;
      top: var(--nav-h); left: 0; right: 0;
      background: rgba(6,8,6,0.98);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      flex-direction: column;
      gap: 0;
      padding: 0.5rem 0 2rem;
      transform: translateY(-110%);
      opacity: 0;
      /* Kapalıyken klavyeyle içine sekme yapılamasın.
         visibility kapanışta animasyon bitince, açılışta ise anında değişsin. */
      visibility: hidden;
      transition: transform .35s ease, opacity .3s ease, visibility 0s linear .35s;
      border-bottom: 1px solid var(--border);
      z-index: 999;
    }
    .navbar.nav-open .nav-links {
      visibility: visible;
      transition: transform .35s ease, opacity .3s ease, visibility 0s;
    }
    .nav-links li { width: 100%; text-align: center; }
    .nav-links a {
      display: block;
      padding: 1rem 0;
      font-size: .9rem;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .nav-links li:last-child a { border-bottom: none; }

    .navbar.nav-open .nav-links {
      transform: translateY(0);
      opacity: 1;
    }

    /* Burger → X animasyonu */
    .nav-burger[aria-expanded='true'] span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-burger[aria-expanded='true'] span:nth-child(2) {
      opacity: 0;
      transform: scaleX(0);
    }
    .nav-burger[aria-expanded='true'] span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement | null;

  // iOS Safari sticky fix: boş touchstart ile dokunma olayları etkinleşir
  navbar?.addEventListener('touchstart', () => {}, { passive: true });

  // Scroll → küçült
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 60);
  });

  function setMenu(open: boolean) {
    navbar?.classList.toggle('nav-open', open);
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Menüyü kapat' : 'Menüyü aç');
  }

  toggle?.addEventListener('click', () => {
    setMenu(toggle.getAttribute('aria-expanded') !== 'true');
  });

  // Escape ile kapat, odağı butona geri ver
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setMenu(false);
      toggle.focus();
    }
  });

  // Menü dışına tıklayınca kapat
  document.addEventListener('click', e => {
    if (toggle?.getAttribute('aria-expanded') !== 'true') return;
    if (!navbar?.contains(e.target as Node)) setMenu(false);
  });

  // Mobil: linke tıklayınca menüyü kapat (logo dahil)
  document.querySelectorAll('.nav-links a, .nav-logo').forEach(link => {
    link.addEventListener('click', () => setMenu(false));
  });
</script>
