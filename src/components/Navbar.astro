---
const links = [
  { href: "/pilot-takim", label: "Pilot Takım" },
  { href: "/mac-gecmisi", label: "Maç Geçmişi" },
  { href: "/a-takim",     label: "A Takım" },
  { href: "/akademi",     label: "Akademi" },
  { href: "/haberler",              label: "Haberler" },
  { href: "/antrenmanlardan-kareler", label: "Galeri" },
];
---

<nav class="navbar" id="navbar">
  <a class="nav-logo" href="/">
    <img src="/logo.jpeg" alt="Kocaeli Kadın FA Logo" class="logo-img" />
    <span class="logo-text">Kocaeli Kadın Futbol Kulübü</span>
  </a>

  <button
    type="button"
    id="nav-toggle"
    class="nav-burger"
    aria-label="Menüyü aç"
    aria-expanded="false"
    aria-controls="nav-links"
  >
    <span></span><span></span><span></span>
  </button>

  <ul class="nav-links" id="nav-links">
    {links.map(l => (
      <li><a href={l.href}>{l.label}</a></li>
    ))}
    <li>
      <a href="/aramiza-katil" class="btn-join">
        <!-- Shimmer: dönen konik degrade, kenar payında görünür -->
        <span class="sb-spark-wrap" aria-hidden="true"><span class="sb-spark"></span></span>
        <span class="sb-text">Aramıza Katıl</span>
        <span class="sb-backdrop" aria-hidden="true"></span>
      </a>
    </li>
  </ul>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    background: rgba(0,0,0,0.93);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 5%;
    z-index: 1000;
    transition: height .3s;
  }
  .navbar.scrolled { height: 58px; }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .logo-img { height: 42px; width: 42px; object-fit: contain; border-radius: 50%; }

  @media (max-width: 768px) {
    .nav-logo { padding: 8px 0; }
    .logo-img { height: 38px; width: 38px; }
  }
  .logo-text {
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: 3px;
    background: linear-gradient(135deg, #fff 0%, var(--green-bright) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    /* Gerçek buton: klavyeyle odaklanabilir ve Enter/Space ile açılır */
    background: none;
    border: none;
    padding: 10px 6px;
    margin: -10px -6px;
    border-radius: 6px;
  }
  .nav-burger span {
    display: block;
    width: 25px; height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: .3s;
  }
  .nav-burger:focus-visible {
    outline: 2px solid var(--green-bright);
    outline-offset: 2px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 2rem;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--text-muted);
    font-size: .85rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color .25s;
  }
  .nav-links a:hover { color: var(--green-bright); }

  /* ── Aramıza Katıl — Shimmer Button (Magic UI portu) ──────────────────
     Çim yeşili zemin, beyaz shimmer. Dönen konik degrade tüm butonu
     kaplar; ortasını backdrop kapatır, geriye yalnızca --cut kadar bir
     kenar payı kalır ve shimmer orada dolaşır. */
  .btn-join {
    --sb-spread: 90deg;
    --sb-shimmer: #ffffff;          /* beyaz */
    --sb-radius: 50px;
    --sb-speed: 3s;
    --sb-cut: 2px;                  /* kenar shimmer kalınlığı */
    --sb-bg: var(--green);          /* çim yeşili */

    position: relative;
    z-index: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    padding: .5rem 1.2rem;
    background: var(--sb-bg);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--sb-radius);
    transition: transform .2s, box-shadow .25s;
  }
  .btn-join:hover {
    --sb-bg: var(--green-mid);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(13,77,30,.45);
  }
  .btn-join:focus-visible { outline: 2px solid var(--green-bright); outline-offset: 2px; }

  /* Metin: her koşulda beyaz (üstteki .nav-links a:hover'ı etkilemesin) */
  .sb-text {
    position: relative;
    z-index: 1;
    color: #fff !important;
    font-weight: 700;
  }

  /* Dönen ışık huzmesi */
  .sb-spark-wrap {
    position: absolute;
    inset: 0;
    z-index: -30;
    overflow: visible;
    container-type: size;
    filter: blur(1.5px);
  }
  .sb-spark {
    position: absolute;
    inset: 0;
    height: 100cqh;
    aspect-ratio: 1;
    animation: sb-slide var(--sb-speed) ease-in-out infinite alternate;
  }
  .sb-spark::before {
    content: '';
    position: absolute;
    inset: -100%;
    background: conic-gradient(
      from calc(270deg - (var(--sb-spread) * 0.5)),
      transparent 0,
      var(--sb-shimmer) var(--sb-spread),
      transparent var(--sb-spread)
    );
    animation: sb-spin calc(var(--sb-speed) * 2) infinite linear;
  }

  /* Ortayı kapatan katman: shimmer sadece kenarda kalsın */
  .sb-backdrop {
    position: absolute;
    z-index: -20;
    inset: var(--sb-cut);
    background: var(--sb-bg);
    border-radius: var(--sb-radius);
    transition: background .25s;
  }

  @keyframes sb-spin {
    0%        { transform: rotate(0deg); }
    15%, 35%  { transform: rotate(90deg); }
    65%, 85%  { transform: rotate(270deg); }
    100%      { transform: rotate(360deg); }
  }
  @keyframes sb-slide {
    to { transform: translate(calc(100cqw - 100%), 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .sb-spark, .sb-spark::before { animation: none; }
    .sb-spark-wrap { display: none; }   /* düz yeşil buton kalır */
  }

  @media (max-width: 768px) {
    /* Tam ad iki satıra düzgün sarılsın (navbar yüksekliğine sığar) */
    .logo-text {
      font-size: .82rem;
      letter-spacing: .5px;
      line-height: 1.15;
      max-width: 180px;
    }

    .nav-burger { display: flex; }

    .nav-links {
      position: fixed;
      top: var(--nav-h); left: 0; right: 0;
      background: rgba(6,8,6,0.98);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      flex-direction: column;
      gap: 0;
      padding: 0.5rem 0 2rem;
      transform: translateY(-110%);
      opacity: 0;
      /* Kapalıyken klavyeyle içine sekme yapılamasın.
         visibility kapanışta animasyon bitince, açılışta ise anında değişsin. */
      visibility: hidden;
      transition: transform .35s ease, opacity .3s ease, visibility 0s linear .35s;
      border-bottom: 1px solid var(--border);
      z-index: 999;
    }
    .navbar.nav-open .nav-links {
      visibility: visible;
      transition: transform .35s ease, opacity .3s ease, visibility 0s;
    }
    .nav-links li { width: 100%; text-align: center; }
    .nav-links a {
      display: block;
      padding: 1rem 0;
      font-size: .9rem;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .nav-links li:last-child a { border-bottom: none; }

    .navbar.nav-open .nav-links {
      transform: translateY(0);
      opacity: 1;
    }

    /* Burger → X animasyonu */
    .nav-burger[aria-expanded='true'] span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-burger[aria-expanded='true'] span:nth-child(2) {
      opacity: 0;
      transform: scaleX(0);
    }
    .nav-burger[aria-expanded='true'] span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement | null;

  // iOS Safari sticky fix: boş touchstart ile dokunma olayları etkinleşir
  navbar?.addEventListener('touchstart', () => {}, { passive: true });

  // Scroll → küçült
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 60);
  });

  function setMenu(open: boolean) {
    navbar?.classList.toggle('nav-open', open);
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Menüyü kapat' : 'Menüyü aç');
  }

  toggle?.addEventListener('click', () => {
    setMenu(toggle.getAttribute('aria-expanded') !== 'true');
  });

  // Escape ile kapat, odağı butona geri ver
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setMenu(false);
      toggle.focus();
    }
  });

  // Menü dışına tıklayınca kapat
  document.addEventListener('click', e => {
    if (toggle?.getAttribute('aria-expanded') !== 'true') return;
    if (!navbar?.contains(e.target as Node)) setMenu(false);
  });

  // Mobil: linke tıklayınca menüyü kapat (logo dahil)
  document.querySelectorAll('.nav-links a, .nav-logo').forEach(link => {
    link.addEventListener('click', () => setMenu(false));
  });
</script>
