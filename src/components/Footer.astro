  </div>

  <!-- Alt bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="copy">© 2026 Kocaeli Kadın Futbol Kulübü. Tüm hakları saklıdır.</p>
      <a href="/admin/dashboard" class="admin-link">Admin Paneli</a>
    </div>
  </div>

</footer>

<style>
  .footer {
    background:
      radial-gradient(ellipse 80% 60% at 20% 0%, rgba(13,77,30,0.12) 0%, transparent 55%),
      var(--black);
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  /* Üst yeşil şerit */
  .footer-accent-bar {
    height: 3px;
    background: linear-gradient(90deg, transparent 0%, var(--green) 30%, var(--green-bright) 50%, var(--green) 70%, transparent 100%);
  }

  /* İçerik grid */
  .footer-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 4.5rem 5% 3.5rem;
    display: grid;
    grid-template-columns: 1.8fr 1fr 1.1fr;
    gap: 3rem;
  }

  @media (max-width: 860px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 500px) {
    .footer-inner { grid-template-columns: 1fr; }
  }

  /* ── Brand ── */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    margin-bottom: 1.3rem;
    width: fit-content;
  }

  .footer-logo-ring {
    position: relative;
    width: 52px; height: 52px;
    border-radius: 50%;
    padding: 2px;
    background: linear-gradient(135deg, var(--green), var(--green-bright));
    flex-shrink: 0;
  }
  .footer-logo-ring::after {
    content: '';
    position: absolute;
    inset: 2px;
    border-radius: 50%;
    background: var(--black);
  }
  .footer-logo-img {
    position: relative;
    z-index: 1;
    width: 100%; height: 100%;
    object-fit: contain;
    border-radius: 50%;
  }

  .footer-logo-texts {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .footer-logo-name {
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: 3px;
    background: linear-gradient(135deg, #fff 0%, var(--green-bright) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1;
  }
  .footer-logo-sub {
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #444;
  }

  .footer-desc {
    font-size: .875rem;
    color: #5a5a5a;
    line-height: 1.7;
    max-width: 280px;
    margin-bottom: 1.8rem;
  }

  .social-links {
    display: flex;
    gap: .55rem;
  }
  .social-btn {
    width: 40px; height: 40px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.03);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #555;
    text-decoration: none;
    transition: border-color .25s, color .25s, background .25s, transform .2s;
  }
  .social-btn:hover {
    border-color: var(--green-bright);
    color: var(--green-bright);
    background: rgba(44,184,74,0.08);
    transform: translateY(-2px);
  }

  /* ── Kolon ── */
  .footer-col h4 {
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: 3.5px;
    text-transform: uppercase;
    color: var(--green-bright);
    margin-bottom: 1.4rem;
    position: relative;
    padding-bottom: .8rem;
  }
  .footer-col h4::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 24px; height: 2px;
    background: var(--green);
    border-radius: 2px;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .55rem;
  }

  .footer-col ul a {
    display: flex;
    align-items: center;
    gap: .6rem;
    text-decoration: none;
    color: #555;
    font-size: .875rem;
    font-weight: 500;
    transition: color .2s, gap .2s;
  }
  .footer-col ul a:hover {
    color: var(--text);
    gap: .9rem;
  }
  .footer-col ul a:hover .link-dot {
    background: var(--green-bright);
    box-shadow: 0 0 6px var(--green-bright);
  }

  .link-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: #333;
    flex-shrink: 0;
    transition: background .2s, box-shadow .2s;
  }

  /* ── İletişim ── */
  .contact-list {
    margin-bottom: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: .9rem !important;
  }

  .contact-list li {
    display: flex;
    align-items: center;
    gap: .75rem;
    color: #555;
    font-size: .875rem;
    font-weight: 500;
  }

  .contact-icon {
    width: 28px; height: 28px;
    border-radius: 8px;
    background: rgba(44,184,74,0.08);
    border: 1px solid rgba(44,184,74,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--green-bright);
  }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .8rem;
    font-weight: 700;
    letter-spacing: .5px;
    color: var(--green-bright);
    text-decoration: none;
    background: rgba(44,184,74,0.08);
    border: 1px solid rgba(44,184,74,0.25);
    padding: .6rem 1.2rem;
    border-radius: 50px;
    transition: background .25s, border-color .25s, gap .2s, transform .2s;
  }
  .footer-cta:hover {
    background: rgba(44,184,74,0.15);
    border-color: var(--green-bright);
    gap: .8rem;
    transform: translateY(-1px);
  }

  /* ── Alt bar ── */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.04);
  }
  .footer-bottom-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 1.1rem 5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .copy {
    font-size: .75rem;
    color: #2e2e2e;
    font-weight: 500;
  }

  .admin-link {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #2a2a2a;
    text-decoration: none;
    transition: color .2s;
  }
  .admin-link:hover { color: var(--green-bright); }
</style>
