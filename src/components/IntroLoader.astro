---
// Siteye giriş animasyonu:
// Çim yeşili–siyah gradient bir ekran, ortasında kulüp arması.
// Önce hafif sönük gelir → tamamen görünür olur → tekrar sönerek kaybolur
// ve kullanıcı sayfada kalır. Oturum başına bir kez oynar.
import { getImage } from 'astro:assets';
import logoSource from '../assets/logo_transparent.png';

// 1254px'lik PNG intro'da en fazla ~360px görünüyor; build'de küçültülmüş
// WebP üretiyoruz (retina için 2x).
const logo = await getImage({ src: logoSource, width: 720, format: 'webp', quality: 90 });
---

<script is:inline>
  // Bu script overlay'den ÖNCE çalışır; böylece "zaten görüldü" durumunda
  // ekran hiç boyanmadan gizlenir (flash olmaz).
  (function () {
    var root = document.documentElement;
    var skip = false;

    try {
      if (sessionStorage.getItem('kkfa-intro-seen') === '1') skip = true;
      else sessionStorage.setItem('kkfa-intro-seen', '1');
    } catch (e) { /* gizli sekme vb. → her açılışta oynasın */ }

    // Hareket azaltma tercihi olan kullanıcılarda animasyon atlanır
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) skip = true;

    if (skip) {
      root.classList.add('kkfa-intro-done');
      return;
    }

    root.classList.add('kkfa-intro-playing');

    setTimeout(function () {
      root.classList.remove('kkfa-intro-playing');
      root.classList.add('kkfa-intro-done');
      var el = document.getElementById('kkfa-intro');
      if (el && el.parentNode) el.parentNode.removeChild(el);
    }, 2600);
  })();
</script>

<div class="intro" id="kkfa-intro" role="presentation" aria-hidden="true">
  <div class="intro-stage">
    <div class="intro-grad"></div>
    <div class="intro-glow"></div>
    <img
      class="intro-logo"
      src={logo.src}
      alt=""
      width={logo.attributes.width ?? 720}
      height={logo.attributes.height ?? 720}
      fetchpriority="high"
      decoding="sync"
      onerror="this.onerror=null;this.src='/logo_transparent.png'"
    />
  </div>
</div>

<noscript>
  <style>#kkfa-intro { display: none !important; }</style>
</noscript>

<style>
  /* Animasyon oynarken sayfa kaymasın */
  :global(html.kkfa-intro-playing),
  :global(html.kkfa-intro-playing body) { overflow: hidden; }

  /* Daha önce görüldüyse hiç render etme */
  :global(html.kkfa-intro-done) .intro { display: none !important; }

  .intro {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: #000;
    display: grid;
    place-items: center;
    overflow: hidden;
    /* 1.75sn sonra sönerek kaybolur */
    animation: intro-out .8s ease 1.75s forwards;
  }

  /* Gradient + logo katmanı: hafif sönük gelip görünür hale gelir */
  .intro-stage {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    animation: intro-rise 1.1s cubic-bezier(.22,.61,.36,1) forwards;
  }

  /* Çim yeşili ↔ siyah, eşit dağıtılmış diyagonal gradient.
     Siyah köşelerde bant olarak tutuluyor; aksi halde diyagonalde
     merkez yeşili tüm ekranı kaplıyor. */
  .intro-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      #000000 0%,
      #000000 20%,
      #063a15 35%,
      #12833a 50%,
      #063a15 65%,
      #000000 80%,
      #000000 100%
    );
  }

  /* Arma daha net okunsun diye merkezde hafif koyulaştırma */
  .intro-grad::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(0,0,0,.42) 0%,
      rgba(0,0,0,.20) 40%,
      rgba(0,0,0,0) 70%
    );
  }

  /* Armanın arkasındaki yumuşak yeşil ışık */
  .intro-glow {
    position: absolute;
    width: min(84vw, 620px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(44,184,74,.30) 0%,
      rgba(13,77,30,.18) 45%,
      rgba(0,0,0,0) 70%
    );
    filter: blur(14px);
    animation: intro-pulse 2.4s ease-in-out infinite;
  }

  /* Şeffaf arma: kutu/çerçeve yok, gölge alfa kanalını takip ediyor */
  .intro-logo {
    position: relative;
    width: clamp(200px, 56vw, 360px);
    height: auto;
    object-fit: contain;
    filter:
      drop-shadow(0 18px 34px rgba(0,0,0,.55))
      drop-shadow(0 0 26px rgba(44,184,74,.28));
    animation: intro-logo 1.4s cubic-bezier(.16,.84,.34,1) forwards;
  }

  @keyframes intro-rise {
    0%   { opacity: .28; filter: brightness(.45) saturate(.6); transform: scale(1.06); }
    100% { opacity: 1;   filter: brightness(1) saturate(1);    transform: scale(1); }
  }

  @keyframes intro-logo {
    0%   { opacity: 0; transform: scale(.82); }
    55%  { opacity: 1; transform: scale(1.03); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes intro-pulse {
    0%, 100% { opacity: .55; transform: scale(.96); }
    50%      { opacity: 1;   transform: scale(1.04); }
  }

  @keyframes intro-out {
    0%   { opacity: 1; filter: brightness(1); }
    100% { opacity: 0; filter: brightness(.2); visibility: hidden; }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro { display: none; }
  }
</style>
