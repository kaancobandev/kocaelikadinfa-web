---
import { supabase, type NewsItem } from '../lib/supabase';

const { data } = await supabase
  .from('news')
  .select('*')
  .order('id', { ascending: false })
  .limit(3);

const slots: (NewsItem | null)[] = [
  data?.[0] ?? null,
  data?.[1] ?? null,
  data?.[2] ?? null,
];

const fallbackImg = 'https://images.unsplash.com/photo-1543326727-cf6c39e8f84c?w=800&q=80';

function linkify(text: string): string {
  return text.replace(
    /(https?:\/\/[^\s<>"']+)/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="news-link">$1</a>'
  );
}
---

<section class="content-cards" id="haberler">
  {slots.map(n => (
    <article class="card reveal">
      <div class="card-img">
        <div
          class="card-img-bg"
          style={`background-image: url('${n?.image_url ?? fallbackImg}')`}
        ></div>
        <img
          class="card-img-fg"
          src={n?.image_url ?? fallbackImg}
          alt={n?.title ?? 'Haber görseli'}
          loading="lazy"
        />
      </div>
      <div class="card-body">
        <span class="card-tag">Haberler</span>
        <h3>{n?.title ?? 'Yakında...'}</h3>
        <p set:html={linkify(n?.description ?? 'İçerik henüz eklenmedi.')}></p>
        <a href="/haberler" class="card-link">Devamını Oku →</a>
      </div>
    </article>
  ))}
</section>

<style>
  .content-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: var(--black);
  }

  @media (max-width: 900px) {
    .content-cards { grid-template-columns: 1fr; }
  }

  .card {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background .25s;
  }
  .card:last-child { border-right: none; }
  .card:hover { background: var(--card-bg); }

  .card-img {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #080808;
  }
  /* Bulanık dolgu: boş kenarları fotoğrafın kendisiyle doldurur */
  .card-img-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(22px) brightness(.4);
    transform: scale(1.2);
  }
  /* Asıl fotoğraf: kırpılmadan, ortalanmış şekilde tamamı görünür */
  .card-img-fg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }
  /* Alt kenarda karta yumuşak geçiş */
  .card-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 68%, rgba(0,0,0,.8) 100%);
    pointer-events: none;
  }

  .card-body {
    padding: 1.8rem 2rem 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: .8rem;
  }

  .card-tag {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green-bright);
  }

  .card-body h3 { font-size: 1.2rem; font-weight: 700; line-height: 1.3; }
  .card-body p  { font-size: .9rem; color: var(--text-muted); flex: 1; }

  .card-body p :global(.news-link) {
    color: #4da6ff;
    text-decoration: underline;
    word-break: break-all;
  }
  .card-body p :global(.news-link:hover) {
    color: #80c1ff;
  }

  .card-link {
    display: inline-block;
    font-size: .85rem;
    font-weight: 700;
    color: var(--green-bright);
    text-decoration: none;
    letter-spacing: .5px;
    transition: color .2s;
  }
  .card-link:hover { color: #fff; }
</style>
