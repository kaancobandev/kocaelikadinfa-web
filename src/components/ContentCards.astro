---
import { supabase, type NewsItem } from '../lib/supabase';
import { img, imgSet } from '../lib/img';
import { newsPath, excerpt, formatDate, isoDate } from '../lib/news';

const { data } = await supabase
  .from('news')
  .select('*')
  .order('id', { ascending: false })
  .limit(3);

const slots: (NewsItem | null)[] = [
  data?.[0] ?? null,
  data?.[1] ?? null,
  data?.[2] ?? null,
];

const fallbackImg = 'https://images.unsplash.com/photo-1543326727-cf6c39e8f84c?w=800&q=80';
---

<section class="content-cards" id="haberler">
  {slots.map(n => (
    <article class="card reveal">
      <div class="card-img">
        <div class="card-img-bg"></div>
        <img
          class="card-img-fg"
          src={img(n?.image_url, 800) || fallbackImg}
          srcset={imgSet(n?.image_url)}
          sizes="(max-width: 900px) 100vw, 33vw"
          alt={n?.title ?? 'Haber görseli'}
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="card-body">
        <div class="card-meta">
          <span class="card-tag">Haberler</span>
          {n && formatDate(n.published_at) && (
            <time class="card-date" datetime={isoDate(n.published_at)}>{formatDate(n.published_at)}</time>
          )}
        </div>
        <h3>{n?.title ?? 'Yakında...'}</h3>
        <p>{n ? excerpt(n.description, 150) : 'İçerik henüz eklenmedi.'}</p>
        <a href={n ? newsPath(n) : '/haberler'} class="card-link">Devamını Oku →</a>
      </div>
    </article>
  ))}
</section>

<style>
  .content-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: var(--black);
  }

  @media (max-width: 900px) {
    .content-cards { grid-template-columns: 1fr; }
  }

  .card {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background .25s;
  }
  .card:last-child { border-right: none; }
  .card:hover { background: var(--card-bg); }

  /* Sabit oran, ama tavanla sınırlı: geniş ekranda kart aşırı uzamıyor */
  .card-img {
    position: relative;
    aspect-ratio: 3 / 4;
    max-height: var(--card-media-max-h);
    overflow: hidden;
    background: #080808;
  }
  /* Tek kolona düşünce oranı koruyup yüksekliği sınırlıyoruz */
  @media (max-width: 900px) {
    .card-img { max-height: 440px; }
  }
  /* Bulanık leke yerine düz koyu panel */
  .card-img-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #141814 0%, #0a0d0a 100%);
  }
  /* Asıl fotoğraf: kırpılmadan, ortalanmış şekilde tamamı görünür */
  .card-img-fg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }
  /* Alt kenarda karta yumuşak geçiş */
  .card-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 68%, rgba(0,0,0,.8) 100%);
    pointer-events: none;
  }

  .card-body {
    padding: 1.8rem 2rem 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: .8rem;
  }

  .card-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: .8rem;
  }
  .card-tag {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green-bright);
  }
  .card-date {
    font-size: .72rem;
    font-weight: 600;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .card-body h3 {
    font-size: 1.2rem; font-weight: 700; line-height: 1.3;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .card-body p {
    font-size: .9rem; color: var(--text-muted); flex: 1;
    display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
  }

  .card-link:focus-visible { outline: 2px solid var(--green-bright); outline-offset: 3px; border-radius: 4px; }

  .card-link {
    display: inline-block;
    font-size: .85rem;
    font-weight: 700;
    color: var(--green-bright);
    text-decoration: none;
    letter-spacing: .5px;
    transition: color .2s;
  }
  .card-link:hover { color: #fff; }
</style>
