---
const stats = [
  { deger: '2016',  etiket: 'Kuruluş' },
  { deger: '1. Lig', etiket: 'A Takım' },
  { deger: '4–16',  etiket: 'Akademi Yaş' },
];
---

<section class="team-section" id="a-takim">
  <div class="team-inner">

    <div class="team-text reveal">
      <span class="section-tag">A Takım</span>
      <h2>Kocaeli'nin Gururu</h2>
      <p>
        A takımımız, bölgenin en köklü kadın futbol ekiplerinden biri olma yolunda emin
        adımlarla ilerliyor. Kadınlar 1. Lig'in tamamen kendi altyapısından beslenen
        kadrosuyla sahadayız.
      </p>

      <div class="team-actions">
        <a href="/a-takim" class="btn-primary">A Takımı Tanı</a>
        <a href="/mac-gecmisi" class="btn-outline">
          Maç Sonuçları
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="team-visual reveal">
      <img src="/a-takim-hero.jpeg" alt="Kocaeli Kadın FK A Takım" loading="lazy" decoding="async" />
      <div class="team-stats">
        {stats.map(s => (
          <div class="stat">
            <span class="stat-num">{s.deger}</span>
            <span class="stat-lbl">{s.etiket}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .team-section {
    background:
      radial-gradient(ellipse 70% 80% at 60% 50%, rgba(13,77,30,0.30) 0%, transparent 65%),
      var(--dark);
    padding: 6rem 5%;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  /* İki kolon — sağ taraf artık boş değil */
  .team-inner {
    max-width: 1160px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .team-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .team-text h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 900;
    margin-bottom: 1rem;
  }
  .team-text p {
    color: var(--text-muted);
    margin-bottom: 2rem;
    max-width: 480px;
    line-height: 1.75;
  }

  .team-actions { display: flex; flex-wrap: wrap; gap: .8rem; }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .8rem 1.6rem;
    border-radius: 50px;
    border: 1px solid rgba(44,184,74,0.3);
    background: rgba(44,184,74,0.06);
    color: var(--green-bright);
    font-size: .9rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-decoration: none;
    transition: background .25s, border-color .25s, gap .2s, transform .2s;
  }
  .btn-outline:hover {
    background: rgba(44,184,74,0.14);
    border-color: var(--green-bright);
    gap: .8rem;
    transform: translateY(-2px);
  }
  .btn-outline:focus-visible { outline: 2px solid var(--green-bright); outline-offset: 3px; }

  /* Görsel + istatistikler */
  .team-visual {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    /* Geniş ekranda kolonun tamamını kaplamasın */
    width: 100%;
    max-width: 460px;
    margin-left: auto;
  }
  .team-visual img {
    display: block;
    width: 100%;
    /* Oran korunur; sınırların dışına taşarsa kırpılır */
    aspect-ratio: 16 / 10;
    min-height: 190px;
    max-height: 290px;
    object-fit: cover;
    object-position: center 35%;
  }

  @media (max-width: 900px) {
    .team-visual { max-width: 560px; margin-inline: auto; }
    .team-visual img { aspect-ratio: 16 / 9; max-height: 260px; }
  }

  .team-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: rgba(0,0,0,.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid var(--border);
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .2rem;
    padding: 1rem .5rem;
  }
  .stat + .stat { border-left: 1px solid rgba(255,255,255,0.07); }
  .stat-num { font-size: 1.15rem; font-weight: 900; color: var(--green-bright); line-height: 1.1; }
  .stat-lbl {
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    text-align: center;
  }
</style>
