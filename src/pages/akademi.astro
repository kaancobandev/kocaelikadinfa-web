---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import { supabase, type GalleryItem } from '../lib/supabase';
import { img, imgSet } from '../lib/img';

const { data } = await supabase
  .from('gallery')
  .select('*')
  .order('sort_order', { ascending: true });

const photos: GalleryItem[] = data ?? [];
---

<Layout
  title="Akademi — Kocaeli Kadın Futbol Kulübü"
  description="Kocaeli Kadın Futbol Kulübü altyapı ve akademisi. Genç yeteneklerin yetiştiği, kadın futboluna oyuncu kazandıran akademimiz."
>
  <Navbar />

  <main class="akademi-page">

    <PageHero
      tag="Akademi"
      title="Geleceğin"
      accent="Yıldızları"
      minHeight="48vh"
    />

    <!-- Metin bölümü -->
    <section class="text-section">
      <div class="text-inner">
        <div class="paragraphs">
          <p>
            Kocaeli Kadın Futbol Akademisi olarak, çocuklarımızın hem eğlenerek geliştiği hem de profesyonel ekipmanlar ve akademik eğitimli antrenörlerimiz eşliğinde geleceğe hazırlandığı bir futbol ortamı sunuyoruz.
          </p>
          <p>
            Kadınlar Süper Ligi'ne altyapısından en çok oyuncu yetiştirip gönderen kulüp olmanın gururunu yaşıyor, geleceğin yıldızlarını yetiştirmeye devam ediyoruz.
          </p>
          <div class="quote-block">
            <p class="quote-text">Hiçbir başarı tesadüf değildir.</p>
            <p class="quote-sub">Başarı; emek, disiplin, inanç ve vazgeçmeden çalışmanın sonucudur.</p>
          </div>
          <p>
            Kocaeli Kadın Futbol Akademisi olarak geleceğin yıldızlarını sabırla, azimle ve profesyonel bir anlayışla yetiştiriyoruz.
          </p>
        </div>
      </div>
    </section>

    <!-- Galeri -->
    {photos.length > 0 && (
      <section class="gallery-section">
        <div class="gallery-header">
          <span class="section-tag">Galeri</span>
          <h2>Akademiden Kareler</h2>
        </div>
        <div class="gallery-grid">
          {photos.map(p => (
            <div class="gallery-item">
              <img
                src={img(p.image_url, 800)}
                srcset={imgSet(p.image_url)}
                sizes="(max-width: 540px) 100vw, (max-width: 900px) 50vw, 33vw"
                alt={p.caption ?? 'Akademi fotoğrafı'}
                loading="lazy"
                decoding="async"
              />
              {p.caption && <div class="gallery-caption">{p.caption}</div>}
            </div>
          ))}
        </div>
      </section>
    )}

    {photos.length === 0 && (
      <section class="gallery-section">
        <div class="gallery-header">
          <span class="section-tag">Galeri</span>
          <h2>Akademiden Kareler</h2>
        </div>
        <div class="gallery-empty">
          <span class="empty-icon">📷</span>
          <p>Fotoğraflar yakında eklenecek.</p>
        </div>
      </section>
    )}

  </main>

  <Footer />
</Layout>

<style>
  /* ── Metin bölümü ── */
  .text-section {
    background: #ffffff;
    border-top: 3px solid var(--green);
    border-bottom: 1px solid #e8e8e8;
    padding: 5rem 8%;
  }
  .text-inner { max-width: 760px; margin: 0 auto; }

  .paragraphs {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }
  .paragraphs p {
    font-size: 1.05rem;
    color: #222;
    line-height: 1.85;
  }

  .quote-block {
    border-left: 4px solid var(--green);
    padding: 1.2rem 2rem;
    background: #f4faf5;
    border-radius: 0 10px 10px 0;
  }
  .quote-text {
    font-size: 1.2rem !important;
    font-weight: 900 !important;
    color: var(--green) !important;
    margin-bottom: .4rem;
  }
  .quote-sub {
    font-size: .95rem !important;
    color: #444 !important;
    font-style: italic;
  }

  /* ── Galeri ── */
  .gallery-section {
    padding: 5rem 8%;
    background: var(--black);
    border-top: 1px solid var(--border);
  }

  .gallery-header {
    margin-bottom: 2.5rem;
  }
  .gallery-header h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 900;
    margin-top: .5rem;
  }

  /* Kolon bazlı masonry: her fotoğraf kendi en-boy oranında durur,
     bulanık dolguya gerek kalmaz. */
  .gallery-grid {
    column-count: 3;
    column-gap: 1rem;
  }
  @media (max-width: 900px) { .gallery-grid { column-count: 2; } }
  @media (max-width: 540px) { .gallery-grid { column-count: 1; } }

  .gallery-item {
    position: relative;
    break-inside: avoid;
    margin-bottom: 1rem;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--card-bg);
    cursor: pointer;
  }
  /* Oran korunur; yalnızca min/max dışına taşanlar kırpılır */
  .gallery-item img {
    display: block;
    width: 100%;
    height: auto;
    min-height: var(--media-min-h);
    max-height: var(--media-max-h);
    object-fit: cover;
    object-position: center 40%;
    transition: transform .4s ease;
  }
  .gallery-item:hover img { transform: scale(1.03); }

  @media (max-width: 540px) {
    .gallery-item img { max-height: var(--media-max-h-sm); }
  }

  .gallery-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 2;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 100%);
    color: #fff;
    font-size: .8rem;
    font-weight: 600;
    padding: 1.2rem .9rem .7rem;
    transform: translateY(100%);
    transition: transform .3s ease;
  }
  .gallery-item:hover .gallery-caption { transform: translateY(0); }

  .gallery-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 4rem 0;
    color: var(--text-muted);
  }
  .empty-icon { font-size: 2.5rem; opacity: .4; }
  .gallery-empty p { font-size: .9rem; letter-spacing: 1px; }
</style>
