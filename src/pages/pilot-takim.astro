---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import { supabase, type GalleryItem } from '../lib/supabase';
import { img, imgSet } from '../lib/img';

const [{ data: settingsData }, { data: galleryData }] = await Promise.all([
  supabase.from('hero_settings').select('image_url').eq('id', 2).single(),
  supabase.from('pilot_gallery').select('*').order('sort_order', { ascending: true }),
]);

const heroImage: string = settingsData?.image_url ?? '/pilot-hero.jpg';
const photos: GalleryItem[] = galleryData ?? [];
---

<Layout
  title="Pilot Takım — Kocaeli Kadın Futbol Kulübü"
  description="Kocaeli Kadın Futbol Kulübü Pilot Takımı: geleceğin yıldız adayları, kadrosu ve fotoğraflarıyla. Kocaeli'de kadın futbolunun temeli."
>
  <Navbar />

  <main class="pt-page">

    <PageHero
      tag="Pilot Takım"
      title="Kocaeli'nin"
      accent="Şampiyonları"
      description="Tutkuyla çalışan, disiplinle oynayan ve sahada hiçbir zaman pes etmeyen bir kadro."
      minHeight="52vh"
      image={img(heroImage, 1600, 70)}
    />

    <!-- Yazı -->
    <section class="story-section">
      <div class="story-inner">
        <h2>Nasıl Oynuyoruz?</h2>
        <div class="story-text">
          <p>
            Pilot takımımız Kocaeli Gölcük İdmanocağı ile sporcularımıza Kadınlar 3. Lig'de forma giyme fırsatı sunuyoruz.
          </p>
          <p>
            Kocaeli Kadın Futbol Akademisi olarak, altyapımızda yetişen sporcularımızın gelişimlerini destekliyor; onları tecrübe kazandırarak Türk kadın futboluna kazandırıyoruz.
          </p>
        </div>

      </div>
    </section>

    <!-- Fotoğraflar -->
    {photos.length > 0 && (
      <section class="photos-section">
        <div class="partner-logo-wrap">
          <img src="/idmanocağı_futbol_kulübü.jpeg" alt="Kocaeli Gölcük İdmanocağı FK" class="partner-logo" />
        </div>
        <h2 class="photos-title">Sahadan Kareler</h2>
        <div class="photos-grid">
          {photos.map(p => (
            <figure class="photo-card">
              <div class="photo-media">
                <img
                  src={img(p.image_url, 800)}
                  srcset={imgSet(p.image_url)}
                  sizes="(max-width: 768px) 100vw, 33vw"
                  alt={p.caption ?? ''}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              {p.caption && <figcaption>{p.caption}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="cta-section">
      <h2>Sen de Aramıza Katıl</h2>
      <p>Pilot takımımıza seçmelere katılmak ya da destek vermek istiyorsan bize ulaş.</p>
      <a href="/aramiza-katil" class="btn-primary">Başvuru Yap</a>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Yazı ── */
  .story-section {
    padding: 6rem 8%;
    background: var(--dark);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .story-inner { max-width: 820px; }

  .story-section h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 900;
    margin-bottom: 2rem;
    position: relative;
    display: inline-block;
  }
  .story-section h2::after {
    content: '';
    display: block;
    width: 50px; height: 3px;
    background: var(--green-bright);
    margin-top: .4rem;
    border-radius: 2px;
  }

  .story-text {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-bottom: 3rem;
  }
  .story-text p {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.85;
  }

  /* ── Partner logo ── */
  .partner-logo-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 2.5rem;
  }
  .partner-logo {
    width: clamp(130px, 26vw, 200px);
    height: clamp(130px, 26vw, 200px);
    object-fit: contain;
    border-radius: 50%;
    border: 2px solid var(--border);
    background: rgba(255,255,255,0.04);
    padding: 6px;
  }

  /* ── Fotoğraflar ── */
  .photos-section {
    padding: 5rem 8%;
    background: var(--black);
  }

  .photos-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 900;
    margin-bottom: 2.5rem;
    position: relative;
    display: inline-block;
  }
  .photos-title::after {
    content: '';
    display: block;
    width: 50px; height: 3px;
    background: var(--green-bright);
    margin-top: .4rem;
    border-radius: 2px;
  }

  /* Kolon bazlı masonry: fotoğraflar kendi oranlarında, bulanık dolgu yok */
  .photos-grid {
    /* Eşit boyutlu kutular: kolon sayısı ekrana göre değişir,
       kutu genişliği kolondan gelir, yükseklik --pt-photo-h ile sabittir. */
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;

    --pt-photo-h: 260px;
  }
  @media (max-width: 980px) {
    .photos-grid { grid-template-columns: repeat(2, 1fr); --pt-photo-h: 240px; }
  }
  @media (max-width: 640px) {
    .photos-grid { grid-template-columns: 1fr; --pt-photo-h: 250px; }
  }
  @media (max-width: 400px) {
    .photos-grid { --pt-photo-h: 210px; }
  }

  .photo-card {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    transition: transform .3s, box-shadow .3s;
  }
  .photo-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,.5);
  }

  /* Tanımlı yükseklik + kolon genişliği → tüm kutular birebir aynı boyutta */
  .photo-media {
    height: var(--pt-photo-h);
    overflow: hidden;
    flex-shrink: 0;
  }
  .photo-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    transition: transform .4s;
  }
  .photo-card:hover img { transform: scale(1.03); }

  figcaption {
    /* Görselin hemen altında; artan yükseklik kartın dibinde kalır */
    background: var(--card-bg);
    padding: .8rem 1rem;
    font-size: .8rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  /* ── CTA ── */
  .cta-section {
    padding: 5rem 8%;
    background: var(--dark);
    border-top: 1px solid var(--border);
    text-align: center;
  }
  .cta-section h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 900; margin-bottom: .8rem; }
  .cta-section p  { color: var(--text-muted); margin-bottom: 2rem; }
</style>
