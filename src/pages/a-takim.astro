---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { supabase, type GalleryItem } from '../lib/supabase';

const { data } = await supabase
  .from('a_takim_gallery')
  .select('*')
  .order('sort_order', { ascending: true });

const photos: GalleryItem[] = data ?? [];
---

<Layout
  title="A Takım — Kocaeli Kadın Futbol Kulübü"
  description="Kocaeli Kadın Futbol Kulübü A Takımı: kadrosu, fotoğrafları ve sahadaki mücadelesi. Süper Lig yolunda Kocaeli'nin gururu."
>
  <Navbar />

  <main class="at-page">

    <!-- Hero -->
    <section class="page-hero">
      <div class="page-hero-inner">
        <span class="tag">A Takım</span>
        <h1>Kocaeli'nin<br /><span>Gururu</span></h1>
        <p>Altyapıya verdiğimiz önem ve genç oyuncularımıza duyduğumuz güvenle, kadın futbolunda sürdürülebilir başarı hedefliyoruz.</p>
      </div>
    </section>

    <!-- Yazı -->
    <section class="story-section">
      <div class="story-inner">
        <h2>Takımımız Hakkında</h2>
        <div class="story-text">
          <p>
            Kadınlar 1. Lig'inin en genç, tamamen yerli ve yabancı oyuncu bulundurmayan tek takımı olarak; başarımızı kendi altyapımızdan yetişen genç yeteneklere verdiğimiz değerle inşa ediyoruz.
          </p>
          <p>
            Kocaeli Kadın Futbol Akademisi olarak geleceği kendi sporcularımızla yazıyoruz.
          </p>
        </div>

      </div>
    </section>

    <!-- Fotoğraflar -->
    {photos.length > 0 && (
      <section class="photos-section">
        <h2 class="photos-title">Sahadan Kareler</h2>
        <div class="photos-grid">
          {photos.map(p => (
            <figure class="photo-card">
              <div class="photo-media" style={`--img: url('${p.image_url}')`}>
                <img src={p.image_url} alt={p.caption ?? ''} loading="lazy" />
              </div>
              {p.caption && <figcaption>{p.caption}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="cta-section">
      <h2>A Takımımıza Katıl</h2>
      <p>Kadromuzda yer almak istiyorsan seçmelerimizi takip et ve başvurunu yap.</p>
      <a href="/aramiza-katil" class="btn-primary">Başvuru Yap</a>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .at-page { }

  /* ── Hero ── */
  .page-hero {
    min-height: 52vh;
    display: flex;
    align-items: center;
    background:
      radial-gradient(ellipse 70% 80% at 80% 50%, rgba(26,122,46,0.22) 0%, transparent 65%),
      linear-gradient(160deg, rgba(10,10,10,0.88) 0%, rgba(13,26,15,0.80) 55%),
      url('/a-takim-hero.jpeg') center/cover no-repeat;
    padding: 5rem 8%;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(26,122,46,0.05) 80px, rgba(26,122,46,0.05) 81px),
      repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(26,122,46,0.05) 80px, rgba(26,122,46,0.05) 81px);
    pointer-events: none;
  }

  .page-hero-inner { position: relative; max-width: 680px; margin-left: auto; }

  .tag {
    display: inline-block;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--green-bright);
    margin-bottom: 1rem;
  }

  .page-hero h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -2px;
    margin-bottom: 1.2rem;
    text-align: right;
  }
  .page-hero h1 span {
    background: linear-gradient(135deg, var(--green-bright) 0%, #5dde7c 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .page-hero p {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 460px;
    margin-left: auto;
    text-align: right;
  }

  /* ── Yazı ── */
  .story-section {
    padding: 6rem 8%;
    background: var(--dark);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .story-inner { max-width: 820px; margin-left: auto; }

  .story-section h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 900;
    margin-bottom: 2rem;
    display: inline-block;
  }
  .story-section h2::after {
    content: '';
    display: block;
    width: 50px; height: 3px;
    background: var(--green-bright);
    margin-top: .4rem;
    border-radius: 2px;
  }

  .story-text { display: flex; flex-direction: column; gap: 1.2rem; }
  .story-text p { font-size: 1rem; color: var(--text-muted); line-height: 1.85; }

  /* ── Fotoğraflar ── */
  .photos-section { padding: 5rem 8%; background: var(--black); }

  .photos-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 900;
    margin-bottom: 2.5rem;
    display: inline-block;
  }
  .photos-title::after {
    content: '';
    display: block;
    width: 50px; height: 3px;
    background: var(--green-bright);
    margin-top: .4rem;
    border-radius: 2px;
  }

  .photos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  @media (max-width: 768px) { .photos-grid { grid-template-columns: 1fr; } }

  .photo-card {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    transition: transform .3s, box-shadow .3s;
  }
  .photo-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.5); }
  .photo-media {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #0a0a0a;
  }
  /* Bulanık dolgu: boş kenarları fotoğrafın kendisiyle doldurur */
  .photo-media::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: var(--img);
    background-size: cover;
    background-position: center;
    filter: blur(22px) brightness(.4);
    transform: scale(1.2);
  }
  /* Asıl fotoğraf: kırpılmadan, ortalanmış şekilde tamamı görünür */
  .photo-card img { position: relative; z-index: 1; width: 100%; height: 100%; object-fit: contain; display: block; transition: transform .4s; }
  .photo-card:hover img { transform: scale(1.04); }
  figcaption { background: var(--card-bg); padding: .8rem 1rem; font-size: .8rem; color: var(--text-muted); font-weight: 600; }

  /* ── CTA ── */
  .cta-section {
    padding: 5rem 8%;
    background: var(--dark);
    border-top: 1px solid var(--border);
    text-align: center;
  }
  .cta-section h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 900; margin-bottom: .8rem; }
  .cta-section p  { color: var(--text-muted); margin-bottom: 2rem; }
</style>
