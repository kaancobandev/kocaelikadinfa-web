---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import { supabase, type GalleryItem } from '../lib/supabase';
import { img, imgSet } from '../lib/img';

const { data } = await supabase
  .from('a_takim_gallery')
  .select('*')
  .order('sort_order', { ascending: true });

const photos: GalleryItem[] = data ?? [];
---

<Layout
  title="A Takım — Kocaeli Kadın Futbol Kulübü"
  description="Kocaeli Kadın Futbol Kulübü A Takımı: kadrosu, fotoğrafları ve sahadaki mücadelesi. Süper Lig yolunda Kocaeli'nin gururu."
>
  <Navbar />

  <main class="at-page">

    <PageHero
      tag="A Takım"
      title="Kocaeli'nin"
      accent="Gururu"
      description="Altyapıya verdiğimiz önem ve genç oyuncularımıza duyduğumuz güvenle, kadın futbolunda sürdürülebilir başarı hedefliyoruz."
      minHeight="52vh"
      image="/a-takim-hero.jpeg"
      align="right"
    />

    <!-- Yazı -->
    <section class="story-section">
      <div class="story-inner">
        <h2>Takımımız Hakkında</h2>
        <div class="story-text">
          <p>
            Kadınlar 1. Lig'inin en genç, tamamen yerli ve yabancı oyuncu bulundurmayan tek takımı olarak; başarımızı kendi altyapımızdan yetişen genç yeteneklere verdiğimiz değerle inşa ediyoruz.
          </p>
          <p>
            Kocaeli Kadın Futbol Akademisi olarak geleceği kendi sporcularımızla yazıyoruz.
          </p>
        </div>

      </div>
    </section>

    <!-- Fotoğraflar -->
    {photos.length > 0 && (
      <section class="photos-section">
        <h2 class="photos-title">Sahadan Kareler</h2>
        <div class="photos-grid">
          {photos.map(p => (
            <figure class="photo-card">
              <div class="photo-media">
                <img
                  src={img(p.image_url, 800)}
                  srcset={imgSet(p.image_url)}
                  sizes="(max-width: 768px) 100vw, 33vw"
                  alt={p.caption ?? ''}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              {p.caption && <figcaption>{p.caption}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="cta-section">
      <h2>A Takımımıza Katıl</h2>
      <p>Kadromuzda yer almak istiyorsan seçmelerimizi takip et ve başvurunu yap.</p>
      <a href="/aramiza-katil" class="btn-primary">Başvuru Yap</a>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Yazı ── */
  .story-section {
    padding: 6rem 8%;
    background: var(--dark);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .story-inner { max-width: 820px; margin-left: auto; }

  .story-section h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 900;
    margin-bottom: 2rem;
    display: inline-block;
  }
  .story-section h2::after {
    content: '';
    display: block;
    width: 50px; height: 3px;
    background: var(--green-bright);
    margin-top: .4rem;
    border-radius: 2px;
  }

  .story-text { display: flex; flex-direction: column; gap: 1.2rem; }
  .story-text p { font-size: 1rem; color: var(--text-muted); line-height: 1.85; }

  /* ── Fotoğraflar ── */
  .photos-section { padding: 5rem 8%; background: var(--black); }

  .photos-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 900;
    margin-bottom: 2.5rem;
    display: inline-block;
  }
  .photos-title::after {
    content: '';
    display: block;
    width: 50px; height: 3px;
    background: var(--green-bright);
    margin-top: .4rem;
    border-radius: 2px;
  }

  /* Kolon bazlı masonry: fotoğraflar kendi oranlarında, bulanık dolgu yok */
  .photos-grid {
    column-count: 3;
    column-gap: 1.2rem;
  }
  @media (max-width: 980px) { .photos-grid { column-count: 2; } }
  @media (max-width: 640px) { .photos-grid { column-count: 1; } }

  .photo-card {
    break-inside: avoid;
    margin-bottom: 1.2rem;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--card-bg);
    transition: transform .3s, box-shadow .3s;
  }
  .photo-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.5); }
  .photo-media { overflow: hidden; }
  /* Oran korunur; yalnızca min/max dışına taşanlar kırpılır */
  .photo-card img {
    display: block;
    width: 100%;
    height: auto;
    min-height: var(--media-min-h);
    max-height: var(--media-max-h);
    object-fit: cover;
    object-position: center 40%;
    transition: transform .4s;
  }
  .photo-card:hover img { transform: scale(1.03); }

  @media (max-width: 640px) {
    .photo-card img { max-height: var(--media-max-h-sm); }
  }
  figcaption { background: var(--card-bg); padding: .8rem 1rem; font-size: .8rem; color: var(--text-muted); font-weight: 600; }

  /* ── CTA ── */
  .cta-section {
    padding: 5rem 8%;
    background: var(--dark);
    border-top: 1px solid var(--border);
    text-align: center;
  }
  .cta-section h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 900; margin-bottom: .8rem; }
  .cta-section p  { color: var(--text-muted); margin-bottom: 2rem; }
</style>
