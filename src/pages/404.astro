---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';

const links = [
  { href: '/',                        label: 'Ana Sayfa',      desc: 'Son haberler ve maç sonuçları' },
  { href: '/haberler',                label: 'Haberler',       desc: 'Kulüpten son gelişmeler' },
  { href: '/mac-gecmisi',             label: 'Maç Geçmişi',    desc: 'Tüm maç sonuçlarımız' },
  { href: '/a-takim',                 label: 'A Takım',        desc: 'Kadromuz ve sahadan kareler' },
  { href: '/pilot-takim',             label: 'Pilot Takım',    desc: 'Geleceğin yıldız adayları' },
  { href: '/akademi',                 label: 'Akademi',        desc: 'Altyapı ve genç yetenekler' },
  { href: '/antrenmanlardan-kareler', label: 'Galeri',         desc: 'Fotoğraf ve videolar' },
  { href: '/aramiza-katil',           label: 'Aramıza Katıl',  desc: 'Başvuru ve iletişim' },
];
---

<Layout
  title="Sayfa Bulunamadı — Kocaeli Kadın Futbol Kulübü"
  description="Aradığınız sayfa bulunamadı. Kocaeli Kadın Futbol Kulübü sitesinde gezinmeye devam edin."
  noindex={true}
>
  <Navbar />

  <main class="nf-page">
    <PageHero
      tag="404"
      title="Bu Top"
      accent="Auta Gitti"
      description="Aradığın sayfa taşınmış ya da hiç var olmamış olabilir. Aşağıdan devam edebilirsin."
      minHeight="46vh"
      maxTitle="4.6rem"
    >
      <a href="/" class="btn-primary nf-cta">Ana Sayfaya Dön</a>
    </PageHero>

    <section class="nf-links">
      <h2 class="nf-links-title">Belki bunları arıyordun</h2>
      <div class="nf-grid">
        {links.map(l => (
          <a href={l.href} class="nf-card">
            <span class="nf-card-label">{l.label}</span>
            <span class="nf-card-desc">{l.desc}</span>
            <svg class="nf-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .nf-cta { display: inline-block; margin-top: 2rem; }

  /* ── Bağlantılar ── */
  .nf-links {
    padding: 4rem 8% 6rem;
    background: var(--dark);
    border-top: 1px solid var(--border);
  }
  .nf-links-title {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--green-bright);
    margin-bottom: 2rem;
  }

  .nf-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) { .nf-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .nf-grid { grid-template-columns: 1fr; } }

  .nf-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: .35rem;
    padding: 1.3rem 1.3rem 1.4rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color .25s, background .25s, transform .2s;
  }
  .nf-card:hover {
    border-color: var(--green-bright);
    background: #111;
    transform: translateY(-3px);
  }
  .nf-card:focus-visible {
    outline: 2px solid var(--green-bright);
    outline-offset: 3px;
  }

  .nf-card-label { font-size: .95rem; font-weight: 800; color: var(--text); }
  .nf-card-desc  { font-size: .8rem; color: var(--text-muted); line-height: 1.5; }

  .nf-card-arrow {
    position: absolute;
    top: 1.3rem; right: 1.2rem;
    color: #3a3a3a;
    transition: color .25s, transform .25s;
  }
  .nf-card:hover .nf-card-arrow {
    color: var(--green-bright);
    transform: translateX(3px);
  }
</style>
