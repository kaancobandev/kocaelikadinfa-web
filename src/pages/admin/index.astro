---
import { supabase } from '../../lib/supabase';

// Zaten giriş yaptıysa dashboard'a yönlendir
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  const { data: { user } } = await supabase.auth.getUser(accessToken);
  if (user) return Astro.redirect('/admin/dashboard');
}

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email    = form.get('email')?.toString() ?? '';
  const password = form.get('password')?.toString() ?? '';

  const { data, error: authError } = await supabase.auth.signInWithPassword({ email, password });

  if (authError || !data.session) {
    error = 'E-posta veya şifre hatalı.';
  } else {
    // iOS Safari, SameSite/Secure belirtilmemiş çerezleri (özellikle
    // POST→redirect akışında) reddedebiliyor; bu yüzden açıkça ayarlıyoruz.
    // secure yalnızca production'da (HTTPS) — yerel http://localhost dev'i bozmasın diye.
    const isProd = import.meta.env.PROD;
    Astro.cookies.set('sb-access-token',  data.session.access_token,  { path: '/', httpOnly: true, sameSite: 'lax', secure: isProd, maxAge: 60 * 60 * 8 });
    Astro.cookies.set('sb-refresh-token', data.session.refresh_token, { path: '/', httpOnly: true, sameSite: 'lax', secure: isProd, maxAge: 60 * 60 * 24 * 7 });
    return Astro.redirect('/admin/dashboard');
  }
}
---

<!doctype html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Girişi — Kocaeli Kadın FA</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
</head>
<body>
  <main class="login-wrap">

    <!-- Card -->
    <div class="card">
      <!-- ShineBorder: kenarda dolaşan degrade. Maskeyle yalnızca
           çerçeve payı görünür, kartın içi etkilenmez. -->
      <span class="shine-border" aria-hidden="true"></span>

      <!-- CardHeader -->
      <div class="card-header">
        <img src="/logo_transparent.png" alt="" class="card-logo" width="44" height="44" />
        <h1 class="card-title">Yönetim Paneli</h1>
        <p class="card-description">
          Devam etmek için hesap bilgilerini gir.
        </p>
      </div>

      <form method="POST" enctype="application/x-www-form-urlencoded">
        <!-- CardContent -->
        <div class="card-content">
          {error && (
            <div class="alert" role="alert">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
              </svg>
              <span>{error}</span>
            </div>
          )}

          <div class="field-group">
            <div class="field">
              <label for="email">E-posta</label>
              <input
                id="email"
                name="email"
                type="email"
                placeholder="ornek@kocaelikadinfa.com"
                autocomplete="username"
                required
                autofocus
              />
            </div>
            <div class="field">
              <label for="password">Şifre</label>
              <input
                id="password"
                name="password"
                type="password"
                placeholder="••••••••"
                autocomplete="current-password"
                required
              />
            </div>
          </div>
        </div>

        <!-- CardFooter -->
        <div class="card-footer">
          <button type="submit" class="btn">Giriş Yap</button>
        </div>
      </form>
    </div>

    <a href="/" class="back-link">← Anasayfaya dön</a>
  </main>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* ShineBorder renkleri — tek satırda değiştirilebilir */
    --shine-1: #A07CFE;
    --shine-2: #FE8FB5;
    --shine-3: #FFBE7B;
    --shine-width: 2px;      /* orijinal demoda 1px; koyu zeminde 2px daha okunur */
    --shine-duration: 14s;

    --bg:          #09090b;
    --card:        #101013;
    --border:      rgba(255,255,255,0.08);
    --fg:          #fafafa;
    --muted-fg:    #8b8b93;
    --primary:     #1a7a2e;
    --primary-hov: #22963a;
    --ring:        #2cb84a;
  }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--bg);
    color: var(--fg);
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Arka planda hafif derinlik */
    background-image:
      radial-gradient(ellipse 60% 50% at 50% 0%,   rgba(160,124,254,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 50% 100%, rgba(44,184,74,0.06)   0%, transparent 60%);
  }

  .login-wrap {
    width: 100%;
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
  }

  /* ── Card ─────────────────────────────────────────────────────────── */
  .card {
    position: relative;
    width: 100%;
    max-width: 360px;
    overflow: hidden;
    background: var(--card);
    /* Kenarı shine katmanı çiziyor; altta yalnızca çok hafif bir taban durur */
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 14px;
    box-shadow: 0 18px 50px rgba(0,0,0,.55);
  }

  /* ── ShineBorder ──────────────────────────────────────────────────────
     Kutuyu tamamen kaplayan degrade, maske ile içi çıkarılıp yalnızca
     kenar payı bırakılıyor; arka plan konumu animasyonla dolaştırılıyor. */
  .shine-border {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    padding: var(--shine-width);
    pointer-events: none;
    will-change: background-position;

    background-image: radial-gradient(
      transparent,
      transparent,
      var(--shine-1),
      var(--shine-2),
      var(--shine-3),
      transparent,
      transparent
    );
    background-size: 300% 300%;

    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
            mask-composite: exclude;

    animation: shine var(--shine-duration) linear infinite;
  }

  @keyframes shine {
    0%   { background-position: 0% 0%; }
    50%  { background-position: 100% 100%; }
    100% { background-position: 0% 0%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .shine-border { animation: none; background-position: 50% 50%; }
  }

  /* Kart içeriği degradenin üstünde kalsın */
  .card-header,
  .card > form { position: relative; z-index: 1; }

  /* ── CardHeader ───────────────────────────────────────────────────── */
  .card-header {
    display: flex;
    flex-direction: column;
    gap: .38rem;
    padding: 1.5rem 1.5rem 0;
  }
  .card-logo {
    width: 44px;
    height: 44px;
    object-fit: contain;
    margin-bottom: .55rem;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,.5));
  }
  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -.2px;
    line-height: 1.1;
  }
  .card-description {
    font-size: .85rem;
    font-weight: 400;
    color: var(--muted-fg);
    line-height: 1.5;
  }

  /* ── CardContent ──────────────────────────────────────────────────── */
  .card-content { padding: 1.35rem 1.5rem 0; }

  .field-group { display: flex; flex-direction: column; gap: 1rem; }
  .field       { display: flex; flex-direction: column; gap: .5rem; }

  label {
    font-size: .82rem;
    font-weight: 500;
    line-height: 1;
    color: var(--fg);
  }

  input {
    width: 100%;
    height: 40px;
    background: rgba(255,255,255,0.035);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0 .8rem;
    color: var(--fg);
    font-family: inherit;
    font-size: .875rem;
    outline: none;
    transition: border-color .18s, box-shadow .18s, background .18s;
  }
  input::placeholder { color: #55555e; }
  input:hover { border-color: rgba(255,255,255,0.14); }
  input:focus-visible {
    border-color: var(--ring);
    box-shadow: 0 0 0 3px rgba(44,184,74,.16);
    background: rgba(255,255,255,0.05);
  }

  /* ── Uyarı ────────────────────────────────────────────────────────── */
  .alert {
    display: flex;
    align-items: center;
    gap: .55rem;
    background: rgba(220,50,50,.1);
    border: 1px solid rgba(220,50,50,.28);
    color: #ef6a6a;
    border-radius: 8px;
    padding: .65rem .8rem;
    font-size: .82rem;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 1.1rem;
  }
  .alert svg { flex-shrink: 0; }

  /* ── CardFooter ───────────────────────────────────────────────────── */
  .card-footer {
    display: flex;
    align-items: center;
    padding: 1.35rem 1.5rem 1.5rem;
  }

  .btn {
    width: 100%;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--primary);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: inherit;
    font-size: .875rem;
    font-weight: 600;
    letter-spacing: .2px;
    cursor: pointer;
    transition: background .18s, transform .15s, box-shadow .18s;
  }
  .btn:hover {
    background: var(--primary-hov);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(26,122,46,.3);
  }
  .btn:active { transform: translateY(0); }
  .btn:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  /* ── Alt bağlantı ─────────────────────────────────────────────────── */
  .back-link {
    font-size: .8rem;
    font-weight: 500;
    color: var(--muted-fg);
    text-decoration: none;
    transition: color .2s;
  }
  .back-link:hover { color: var(--ring); }
  .back-link:focus-visible { outline: 2px solid var(--ring); outline-offset: 3px; border-radius: 4px; }

  @media (max-width: 380px) {
    .card-header  { padding: 1.25rem 1.15rem 0; }
    .card-content { padding: 1.1rem 1.15rem 0; }
    .card-footer  { padding: 1.1rem 1.15rem 1.25rem; }
  }
</style>
