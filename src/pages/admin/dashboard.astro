---
import { supabase, createUserClient, uploadFile, type Match, type NewsItem, type VideoItem, type GalleryItem, type HeroSettings, type AntrenmanGaleriItem } from '../../lib/supabase';

// Auth kontrolü
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (!accessToken) return Astro.redirect('/admin');

const { data: { user } } = await supabase.auth.getUser(accessToken);
if (!user) {
  Astro.cookies.delete('sb-access-token',  { path: '/' });
  Astro.cookies.delete('sb-refresh-token', { path: '/' });
  return Astro.redirect('/admin');
}

let successMsg = '';
let errorMsg   = '';

// ── Yardımcı: formdan dosya ya da URL al ──────────────────────────────
async function resolveImage(
  form: FormData,
  fileField: string,
  urlField: string,
  folder: string
): Promise<string | null> {
  const file = form.get(fileField) as File | null;
  if (file && file.size > 0) {
    const uploaded = await uploadFile(accessToken!, file, folder);
    if (uploaded) return uploaded;
  }
  return form.get(urlField)?.toString() || null;
}

// ── Form işlemleri ────────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData();
  const action = form.get('_action')?.toString();
  const db     = createUserClient(accessToken!);

  // Hero güncelle
  if (action === 'hero_save') {
    const badge       = form.get('badge')?.toString() ?? '';
    const title       = form.get('title')?.toString() ?? '';
    const description = form.get('description')?.toString() ?? '';
    const image_url   = await resolveImage(form, 'image_file', 'image_url', 'hero');

    const { data: existing } = await supabase.from('hero_settings').select('id').eq('id', 1).single();
    if (existing) {
      const { error } = await db.from('hero_settings').update({ badge, title, description, ...(image_url && { image_url }) }).eq('id', 1);
      errorMsg   = error ? 'Kaydedilemedi: ' + error.message : '';
      successMsg = error ? '' : 'Hero güncellendi!';
    } else {
      const { error } = await db.from('hero_settings').insert({ id: 1, badge, title, description, image_url });
      errorMsg   = error ? 'Kaydedilemedi: ' + error.message : '';
      successMsg = error ? '' : 'Hero oluşturuldu!';
    }
  }

  // Maç güncelle
  if (action === 'update') {
    const id         = Number(form.get('id'));
    const badge      = form.get('badge')?.toString() ?? '';
    const home_name  = form.get('home_name')?.toString() ?? '';
    const away_name  = form.get('away_name')?.toString() ?? '';
    const score_home = Number(form.get('score_home'));
    const score_away = Number(form.get('score_away'));
    const match_date = form.get('match_date')?.toString() ?? '';
    const league     = form.get('league')?.toString() ?? '';

    const home_logo = await resolveImage(form, 'home_logo_file', 'home_logo_url', 'logos');
    const away_logo = await resolveImage(form, 'away_logo_file', 'away_logo_url', 'logos');

    const { error } = await db
      .from('matches')
      .update({ badge, home_name, home_logo, away_name, away_logo, score_home, score_away, match_date, league })
      .eq('id', id);

    errorMsg   = error ? 'Güncelleme başarısız: ' + error.message : '';
    successMsg = error ? '' : 'Maç güncellendi!';
  }

  // Maç sil
  if (action === 'delete') {
    const id = Number(form.get('id'));
    const { error } = await db.from('matches').delete().eq('id', id);
    errorMsg   = error ? 'Silme başarısız.' : '';
    successMsg = error ? '' : 'Maç silindi.';
  }

  // Maç ekle
  if (action === 'match_add') {
    const badge      = form.get('badge')?.toString() ?? '';
    const home_name  = form.get('home_name')?.toString() ?? '';
    const away_name  = form.get('away_name')?.toString() ?? '';
    const score_home = Number(form.get('score_home'));
    const score_away = Number(form.get('score_away'));
    const match_date = form.get('match_date')?.toString() ?? '';
    const league     = form.get('league')?.toString() ?? '';
    const sort_order = Number(form.get('sort_order') ?? 99);

    const home_logo = await resolveImage(form, 'home_logo_file', 'home_logo_url', 'logos');
    const away_logo = await resolveImage(form, 'away_logo_file', 'away_logo_url', 'logos');

    const { error } = await db
      .from('matches')
      .insert({ badge, home_name, home_logo, away_name, away_logo, score_home, score_away, match_date, league, sort_order });

    errorMsg   = error ? 'Maç eklenemedi: ' + error.message : '';
    successMsg = error ? '' : 'Yeni maç eklendi!';
  }

  // Haber kaydet (upsert — sort_order 1/2/3 sabit slot)
  if (action === 'news_save') {
    const slot        = Number(form.get('slot'));
    const existingId  = form.get('existing_id')?.toString();
    const title       = form.get('title')?.toString() ?? '';
    const description = form.get('description')?.toString() ?? '';
    const image_url   = await resolveImage(form, 'image_file', 'image_url', 'news');

    if (existingId) {
      const { error } = await db
        .from('news')
        .update({ title, description, image_url })
        .eq('id', Number(existingId));
      errorMsg   = error ? 'Kaydedilemedi: ' + error.message : '';
      successMsg = error ? '' : `Haber ${slot} güncellendi!`;
    } else {
      const { error } = await db
        .from('news')
        .insert({ title, description, image_url, sort_order: slot });
      errorMsg   = error ? 'Kaydedilemedi: ' + error.message : '';
      successMsg = error ? '' : `Haber ${slot} eklendi!`;
    }
  }

  // Pilot Takım hero görseli kaydet
  if (action === 'pilot_hero_save') {
    const image_url = await resolveImage(form, 'image_file', 'image_url', 'pilot-hero');
    if (!image_url) {
      errorMsg = 'Lütfen bir görsel seçin veya URL girin.';
    } else {
      const { data: existing } = await supabase.from('hero_settings').select('id').eq('id', 2).single();
      if (existing) {
        const { error } = await db.from('hero_settings').update({ image_url }).eq('id', 2);
        errorMsg   = error ? 'Kaydedilemedi: ' + error.message : '';
        successMsg = error ? '' : 'Pilot Takım hero görseli güncellendi!';
      } else {
        const { error } = await db.from('hero_settings').insert({ id: 2, badge: '', title: '', description: '', image_url });
        errorMsg   = error ? 'Kaydedilemedi: ' + error.message : '';
        successMsg = error ? '' : 'Pilot Takım hero görseli eklendi!';
      }
    }
  }

  // A Takım galeri fotoğraf ekle
  if (action === 'a_takim_gallery_add') {
    const caption    = form.get('caption')?.toString() ?? '';
    const sort_order = Number(form.get('sort_order') ?? 99);
    const image_url  = await resolveImage(form, 'image_file', 'image_url', 'a-takim-gallery');

    if (!image_url) {
      errorMsg = 'Lütfen bir fotoğraf seçin veya URL girin.';
    } else {
      const { error } = await db.from('a_takim_gallery').insert({ image_url, caption, sort_order });
      errorMsg   = error ? 'Eklenemedi: ' + error.message : '';
      successMsg = error ? '' : 'Fotoğraf eklendi!';
    }
  }

  // A Takım galeri fotoğraf sil
  if (action === 'a_takim_gallery_delete') {
    const id = Number(form.get('id'));
    const { error } = await db.from('a_takim_gallery').delete().eq('id', id);
    errorMsg   = error ? 'Silinemedi.' : '';
    successMsg = error ? '' : 'Fotoğraf silindi.';
  }

  // Pilot Takım galeri fotoğraf ekle
  if (action === 'pilot_gallery_add') {
    const caption    = form.get('caption')?.toString() ?? '';
    const sort_order = Number(form.get('sort_order') ?? 99);
    const image_url  = await resolveImage(form, 'image_file', 'image_url', 'pilot-gallery');

    if (!image_url) {
      errorMsg = 'Lütfen bir fotoğraf seçin veya URL girin.';
    } else {
      const { error } = await db.from('pilot_gallery').insert({ image_url, caption, sort_order });
      errorMsg   = error ? 'Eklenemedi: ' + error.message : '';
      successMsg = error ? '' : 'Fotoğraf eklendi!';
    }
  }

  // Pilot Takım galeri fotoğraf sil
  if (action === 'pilot_gallery_delete') {
    const id = Number(form.get('id'));
    const { error } = await db.from('pilot_gallery').delete().eq('id', id);
    errorMsg   = error ? 'Silinemedi.' : '';
    successMsg = error ? '' : 'Fotoğraf silindi.';
  }

  // Galeri fotoğraf ekle
  if (action === 'gallery_add') {
    const caption     = form.get('caption')?.toString() ?? '';
    const sort_order  = Number(form.get('sort_order') ?? 99);
    const image_url   = await resolveImage(form, 'image_file', 'image_url', 'gallery');

    if (!image_url) {
      errorMsg = 'Lütfen bir fotoğraf seçin veya URL girin.';
    } else {
      const { error } = await db
        .from('gallery')
        .insert({ image_url, caption, sort_order });
      errorMsg   = error ? 'Eklenemedi: ' + error.message : '';
      successMsg = error ? '' : 'Fotoğraf eklendi!';
    }
  }

  // Galeri fotoğraf sil
  if (action === 'gallery_delete') {
    const id = Number(form.get('id'));
    const { error } = await db.from('gallery').delete().eq('id', id);
    errorMsg   = error ? 'Silinemedi.' : '';
    successMsg = error ? '' : 'Fotoğraf silindi.';
  }

  // published_at sütunu migrations/001 çalıştırılana kadar tabloda olmayabilir.
  // O durumda alanı düşürüp tekrar deniyoruz ki haber ekleme/güncelleme bozulmasın.
  const missingPublishedAt = (msg?: string) =>
    !!msg && /published_at/i.test(msg) && /(column|schema cache)/i.test(msg);

  // Haber makale ekle
  if (action === 'article_add') {
    const title        = form.get('title')?.toString() ?? '';
    const description  = form.get('description')?.toString() ?? '';
    const published_at = form.get('published_at')?.toString() || null;
    const image_url    = await resolveImage(form, 'image_file', 'image_url', 'news');

    let { error } = await db.from('news').insert({ title, description, image_url, published_at, sort_order: 0 });
    if (missingPublishedAt(error?.message)) {
      ({ error } = await db.from('news').insert({ title, description, image_url, sort_order: 0 }));
    }
    errorMsg   = error ? 'Eklenemedi: ' + error.message : '';
    successMsg = error ? '' : 'Haber eklendi!';
  }

  // Haber makale güncelle
  if (action === 'article_update') {
    const id           = Number(form.get('id'));
    const title        = form.get('title')?.toString() ?? '';
    const description  = form.get('description')?.toString() ?? '';
    const published_at = form.get('published_at')?.toString() || null;
    const image_url    = await resolveImage(form, 'image_file', 'image_url', 'news');

    let { error } = await db
      .from('news')
      .update({ title, description, published_at, ...(image_url && { image_url }) })
      .eq('id', id);
    if (missingPublishedAt(error?.message)) {
      ({ error } = await db
        .from('news')
        .update({ title, description, ...(image_url && { image_url }) })
        .eq('id', id));
    }
    errorMsg = error
      ? 'Kaydedilemedi: ' + error.message
      : '';
    successMsg = error ? '' : 'Haber güncellendi!';
  }

  // Haber makale sil
  if (action === 'article_delete') {
    const id = Number(form.get('id'));
    const { error } = await db.from('news').delete().eq('id', id);
    errorMsg   = error ? 'Silinemedi.' : '';
    successMsg = error ? '' : 'Haber silindi.';
  }

  // Video kaydet (sort_order 1/2/3 sabit slot)
  if (action === 'video_save') {
    const slot        = Number(form.get('slot'));
    const existingId  = form.get('existing_id')?.toString();
    const title       = form.get('title')?.toString() ?? '';
    const description = form.get('description')?.toString() ?? '';
    const youtube_url = form.get('youtube_url')?.toString() ?? '';

    if (existingId) {
      const { error } = await db
        .from('videos')
        .update({ title, description, youtube_url })
        .eq('id', Number(existingId));
      errorMsg   = error ? 'Kaydedilemedi: ' + error.message : '';
      successMsg = error ? '' : `Video ${slot} güncellendi!`;
    } else {
      const { error } = await db
        .from('videos')
        .insert({ title, description, youtube_url, sort_order: slot });
      errorMsg   = error ? 'Kaydedilemedi: ' + error.message : '';
      successMsg = error ? '' : `Video ${slot} eklendi!`;
    }
  }

  // Antrenman Galerisi — fotoğraf/video ekle
  if (action === 'antrenman_add') {
    const caption    = form.get('caption')?.toString() ?? '';
    const sort_order = Number(form.get('sort_order') ?? 99);

    // Önce dosya yüklemeyi dene, yoksa URL veya YouTube linki al
    const file = form.get('image_file') as File | null;
    let media_url: string | null = null;
    if (file && file.size > 0) {
      media_url = await uploadFile(accessToken!, file, 'antrenman-galeri');
    }
    if (!media_url) media_url = form.get('media_url')?.toString() || null;

    if (!media_url) {
      errorMsg = 'Lütfen bir fotoğraf seçin, URL veya YouTube linki girin.';
    } else {
      const { error } = await db.from('antrenman_galeri').insert({ media_url, caption, sort_order });
      errorMsg   = error ? 'Eklenemedi: ' + error.message : '';
      successMsg = error ? '' : 'İçerik eklendi!';
    }
  }

  // Antrenman Galerisi — sil
  if (action === 'antrenman_delete') {
    const id = Number(form.get('id'));
    const { error } = await db.from('antrenman_galeri').delete().eq('id', id);
    errorMsg   = error ? 'Silinemedi.' : '';
    successMsg = error ? '' : 'İçerik silindi.';
  }

  // Çıkış
  if (action === 'logout') {
    Astro.cookies.delete('sb-access-token',  { path: '/' });
    Astro.cookies.delete('sb-refresh-token', { path: '/' });
    return Astro.redirect('/admin');
  }
}

// Verileri çek
const { data }      = await supabase.from('matches').select('*').order('id', { ascending: false });
const matches: Match[] = data ?? [];

// Maçları kategori (badge) başlığına göre dinamik grupla
const matchGroupMap = new Map<string, Match[]>();
for (const m of matches) {
  const key = m.badge || 'Diğer';
  if (!matchGroupMap.has(key)) matchGroupMap.set(key, []);
  matchGroupMap.get(key)!.push(m);
}
const matchGroups: [string, Match[]][] = [...matchGroupMap.entries()];

const { data: allArticlesData } = await supabase.from('news').select('*').order('id', { ascending: false });
const allArticles: NewsItem[] = allArticlesData ?? [];

const { data: newsData } = await supabase.from('news').select('*').in('sort_order', [1, 2, 3, 4]);
const newsSlots: (NewsItem | null)[] = [
  newsData?.find(n => n.sort_order === 1) ?? null,
  newsData?.find(n => n.sort_order === 2) ?? null,
  newsData?.find(n => n.sort_order === 3) ?? null,
  newsData?.find(n => n.sort_order === 4) ?? null,
];


const { data: heroData } = await supabase.from('hero_settings').select('*').eq('id', 1).single();
const hero: HeroSettings | null = heroData ?? null;

const { data: galleryData } = await supabase.from('gallery').select('*').order('sort_order');
const galleryPhotos: GalleryItem[] = galleryData ?? [];

const { data: pilotHeroData } = await supabase.from('hero_settings').select('image_url').eq('id', 2).single();
const pilotHeroImage: string | null = pilotHeroData?.image_url ?? null;

const { data: pilotGalleryData } = await supabase.from('pilot_gallery').select('*').order('sort_order');
const pilotPhotos: GalleryItem[] = pilotGalleryData ?? [];

const { data: aTakimGalleryData } = await supabase.from('a_takim_gallery').select('*').order('sort_order');
const aTakimPhotos: GalleryItem[] = aTakimGalleryData ?? [];

const { data: antrenmanData } = await supabase.from('antrenman_galeri').select('*').order('sort_order');
const antrenmanItems: AntrenmanGaleriItem[] = antrenmanData ?? [];

const { data: videoData } = await supabase.from('videos').select('*').order('sort_order').limit(3);
const videoSlots: (VideoItem | null)[] = [
  videoData?.find(v => v.sort_order === 1) ?? null,
  videoData?.find(v => v.sort_order === 2) ?? null,
  videoData?.find(v => v.sort_order === 3) ?? null,
];


---

<!doctype html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — Kocaeli Kadın FA Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="topbar">
    <div class="topbar-left">
      <img src="/logo.jpeg" alt="Kocaeli Kadın FA" class="topbar-logo" />
      <span class="logo">Kocaeli Kadın FA Admin</span>
    </div>
    <div class="topbar-right">
      <span class="user-email">{user.email}</span>
      <form method="POST" enctype="application/x-www-form-urlencoded" style="display:inline">
        <input type="hidden" name="_action" value="logout" />
        <button class="btn-logout">Çıkış</button>
      </form>
      <a href="/" class="btn-site">Siteye Git →</a>
    </div>
  </header>

  <main class="dashboard">

    {successMsg && <div class="alert success">{successMsg}</div>}
    {errorMsg   && <div class="alert error">{errorMsg}</div>}

    <!-- ── HERO ── -->
    <section class="panel">
      <h2>Ana Sayfa Hero</h2>
      <form method="POST" enctype="multipart/form-data" class="match-form" style="border-bottom:none;margin-bottom:0;padding-bottom:0">
        <input type="hidden" name="_action" value="hero_save" />

        <div class="form-row">
          <label>Rozet (örn: Son Dakika)
            <input name="badge" value={hero?.badge ?? ''} placeholder="Son Dakika" />
          </label>
        </div>

        <div class="form-row">
          <label style="flex:1">Başlık (satır atlamak için yeni satıra geç)
            <textarea name="title" rows="3" placeholder="SÜPER LIG'E EN FAZLA...">{hero?.title ?? ''}</textarea>
          </label>
        </div>

        <div class="form-row">
          <label style="flex:1">Açıklama
            <textarea name="description" rows="2" placeholder="Kısa açıklama...">{hero?.description ?? ''}</textarea>
          </label>
        </div>

        <div class="form-row">
          <label>Arka Plan Görseli — Cihazdan Yükle
            <div class="file-wrap">
              {hero?.image_url && <img src={hero.image_url} class="news-preview" alt="hero görseli" />}
              <input type="file" name="image_file" accept="image/*" class="file-input" />
            </div>
          </label>
          <label>veya Görsel URL
            <input name="image_url" value={hero?.image_url ?? ''} placeholder="https://..." />
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">Kaydet</button>
        </div>
      </form>

      <!-- Diğer Manşetler -->
      <div class="hero-divider">
        <span class="slot-label">Diğer Manşetler (Hero Sağ Panel)</span>
        <p class="hero-divider-note">Aşağıdaki 2 haber, hero'nun sağ tarafında görünür.</p>
      </div>
      <div class="news-slots" style="margin-top:.6rem;grid-template-columns:repeat(2,1fr)">
        {[newsSlots[0], newsSlots[1], newsSlots[2], newsSlots[3]].map((n, i) => {
          const slot = i + 1;
          return (
            <form method="POST" enctype="multipart/form-data" class="news-slot-form">
              <input type="hidden" name="_action"     value="news_save" />
              <input type="hidden" name="slot"        value={slot} />
              <input type="hidden" name="existing_id" value={n?.id ?? ''} />

              <p class="slot-label">Manşet {slot}</p>

              <label>Başlık
                <input name="title" value={n?.title ?? ''} placeholder="Haber başlığı" />
              </label>

              <label>Açıklama
                <textarea name="description" rows="2" placeholder="Kısa açıklama...">{n?.description ?? ''}</textarea>
              </label>

              <label>Görsel — Cihazdan Yükle
                <div class="file-wrap">
                  {n?.image_url && <img src={n.image_url} class="news-preview" alt="önizleme" />}
                  <input type="file" name="image_file" accept="image/*" class="file-input" />
                </div>
              </label>

              <label>veya Görsel URL
                <input name="image_url" value={n?.image_url ?? ''} placeholder="https://..." />
              </label>

              <div class="form-actions">
                <button type="submit" class="btn-save">Kaydet</button>
              </div>
            </form>
          );
        })}
      </div>
    </section>

    <!-- ── MAÇ SONUÇLARI ── -->
    <section class="panel">
      <h2>Maç Sonuçları</h2>

      <!-- Mevcut maçlar — kategori başlığına göre dinamik listeleme -->
      {matchGroups.map(([title, list]) => (
        <div class="match-subsection">
          <p class="subsection-label">{title}</p>
          <div class="article-list">
            {list.map(m => (
              <div class="article-row">
                <div class="article-meta">
                  <span class="article-title">{m.home_name} {m.score_home} – {m.score_away} {m.away_name}</span>
                  <span class="article-desc">{m.match_date}</span>
                </div>
                <form method="POST" enctype="application/x-www-form-urlencoded" class="article-delete-form">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={m.id} />
                  <button type="submit" class="btn-delete btn-delete-small">Sil</button>
                </form>
              </div>
            ))}
          </div>
        </div>
      ))}

      {matches.length === 0 && (
        <p class="empty-hint">Henüz maç eklenmemiş. Aşağıdan ilk maçı ekleyebilirsiniz.</p>
      )}

      <!-- Tek Maç Ekleme Formu — kategori başlığını siz yazarsınız -->
      <form method="POST" enctype="multipart/form-data" class="match-form new-match">
        <input type="hidden" name="_action" value="match_add" />
        <input type="hidden" name="sort_order" value="99" />
        <p class="slot-label">+ Yeni Maç Ekle</p>

        <div class="form-row">
          <label>Kategori / Başlık
            <input name="badge" list="badge-options" placeholder="örn. U13, U15, 1.Lig" required />
            <datalist id="badge-options">
              {matchGroups.map(([title]) => <option value={title} />)}
            </datalist>
          </label>
          <label>Tarih
            <input type="date" name="match_date" required />
          </label>
        </div>

        <div class="form-row teams-row">
          <div class="team-block">
            <span class="team-label">Ev Sahibi</span>
            <label>Takım Adı
              <input name="home_name" placeholder="KKFK" required />
            </label>
            <label>Logo — Cihazdan Yükle
              <input type="file" name="home_logo_file" accept="image/*" class="file-input" />
            </label>
            <label>veya URL
              <input name="home_logo_url" placeholder="https://..." />
            </label>
          </div>

          <div class="score-block">
            <label>Skor
              <div class="score-inputs">
                <input type="number" name="score_home" value="0" min="0" required />
                <span>–</span>
                <input type="number" name="score_away" value="0" min="0" required />
              </div>
            </label>
          </div>

          <div class="team-block">
            <span class="team-label">Deplasman</span>
            <label>Takım Adı
              <input name="away_name" placeholder="Rakip FK" required />
            </label>
            <label>Logo — Cihazdan Yükle
              <input type="file" name="away_logo_file" accept="image/*" class="file-input" />
            </label>
            <label>veya URL
              <input name="away_logo_url" placeholder="https://..." />
            </label>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">Maç Ekle</button>
        </div>
      </form>
    </section>

    <!-- ── HABERLER ── -->
    <section class="panel">
      <h2>Haberler</h2>

      {allArticles.length > 0 && (
        <div class="article-list">
          {allArticles.map(n => (
            <div class="article-block">
              <div class="article-row">
                {n.image_url && <img src={n.image_url} alt={n.title} class="article-thumb" />}
                <div class="article-meta">
                  <span class="article-title">{n.title}</span>
                  <span class={`article-date-badge${n.published_at ? '' : ' missing'}`}>
                    {n.published_at ? n.published_at : 'tarih yok'}
                  </span>
                  {n.description && <span class="article-desc">{n.description}</span>}
                </div>
                <form method="POST" enctype="application/x-www-form-urlencoded" class="article-delete-form">
                  <input type="hidden" name="_action" value="article_delete" />
                  <input type="hidden" name="id" value={n.id} />
                  <button type="submit" class="btn-delete btn-delete-small">Sil</button>
                </form>
              </div>

              <details class="article-edit">
                <summary>Düzenle</summary>
                <form method="POST" enctype="multipart/form-data" class="match-form">
                  <input type="hidden" name="_action" value="article_update" />
                  <input type="hidden" name="id" value={n.id} />

                  <div class="form-row">
                    <label style="flex:2">Başlık
                      <input name="title" value={n.title} required />
                    </label>
                    <label style="flex:1">Yayın Tarihi
                      <input type="date" name="published_at" value={n.published_at ?? ''} />
                    </label>
                  </div>

                  <div class="form-row">
                    <label style="flex:1">Açıklama
                      <textarea name="description" rows="4">{n.description}</textarea>
                    </label>
                  </div>

                  <div class="form-row">
                    <label>Görseli Değiştir — Cihazdan Yükle
                      <div class="file-wrap">
                        <input type="file" name="image_file" accept="image/*" class="file-input" />
                      </div>
                    </label>
                    <label>veya Görsel URL
                      <input name="image_url" placeholder="Boş bırakılırsa mevcut görsel korunur" />
                    </label>
                  </div>

                  <div class="form-actions">
                    <button type="submit" class="btn-save">Kaydet</button>
                  </div>
                </form>
              </details>
            </div>
          ))}
        </div>
      )}

      <form method="POST" enctype="multipart/form-data" class="match-form new-match" style="margin-top:1.4rem">
        <input type="hidden" name="_action" value="article_add" />
        <p class="slot-label">+ Yeni Haber Ekle</p>

        <div class="form-row">
          <label style="flex:2">Başlık
            <input name="title" placeholder="Haber başlığı" required />
          </label>
          <label style="flex:1">Yayın Tarihi
            <input type="date" name="published_at" />
          </label>
        </div>

        <div class="form-row">
          <label style="flex:1">Açıklama
            <textarea name="description" rows="3" placeholder="Haber içeriği..."></textarea>
          </label>
        </div>

        <div class="form-row">
          <label>Görsel — Cihazdan Yükle
            <div class="file-wrap">
              <input type="file" name="image_file" accept="image/*" class="file-input" />
            </div>
          </label>
          <label>veya Görsel URL
            <input name="image_url" placeholder="https://..." />
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">Haber Ekle</button>
        </div>
      </form>
    </section>

    <!-- ── ANTRENMANLARDAN KARELER ── -->
    <section class="panel">
      <h2>Antrenmanlardan Kareler</h2>

      {antrenmanItems.length > 0 && (
        <div class="gallery-admin-grid">
          {antrenmanItems.map(item => {
            const isYt = /youtu(\.be|be\.com)/i.test(item.media_url);
            const ytId = item.media_url.match(/(?:v=|youtu\.be\/|embed\/|shorts\/)([A-Za-z0-9_-]{11})/)?.[1];
            return (
              <div class="gallery-admin-item">
                {isYt && ytId ? (
                  <img
                    src={`https://img.youtube.com/vi/${ytId}/hqdefault.jpg`}
                    alt={item.caption ?? ''}
                    class="gallery-thumb"
                  />
                ) : (
                  <img src={item.media_url} alt={item.caption ?? ''} class="gallery-thumb" />
                )}
                {isYt && <div class="yt-badge">▶ YT</div>}
                {item.caption && <p class="gallery-admin-caption">{item.caption}</p>}
                <form method="POST" enctype="application/x-www-form-urlencoded" class="gallery-delete-form">
                  <input type="hidden" name="_action" value="antrenman_delete" />
                  <input type="hidden" name="id" value={item.id} />
                  <button type="submit" class="btn-delete btn-delete-small">Sil</button>
                </form>
              </div>
            );
          })}
        </div>
      )}

      <form method="POST" enctype="multipart/form-data" class="match-form new-match" style="margin-top:1.4rem">
        <input type="hidden" name="_action" value="antrenman_add" />
        <p class="slot-label">+ Fotoğraf veya Video Ekle</p>

        <div class="form-row">
          <label>Açıklama (isteğe bağlı)
            <input name="caption" placeholder="Fotoğraf/video açıklaması..." />
          </label>
          <label>Sıra
            <input type="number" name="sort_order" value="99" min="0" />
          </label>
        </div>

        <div class="form-row">
          <label>Fotoğraf — Cihazdan Yükle
            <div class="file-wrap">
              <input type="file" name="image_file" accept="image/*,video/*" class="file-input" />
            </div>
          </label>
          <label>veya Görsel URL / YouTube Linki
            <input name="media_url" placeholder="https://... veya https://youtube.com/watch?v=..." />
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">Ekle</button>
        </div>
      </form>
    </section>

    <!-- ── A TAKIM GALERİSİ ── -->
    <section class="panel">
      <h2>A Takım Galerisi</h2>

      {aTakimPhotos.length > 0 && (
        <div class="gallery-admin-grid">
          {aTakimPhotos.map(p => (
            <div class="gallery-admin-item">
              <img src={p.image_url} alt={p.caption ?? ''} class="gallery-thumb" />
              {p.caption && <p class="gallery-admin-caption">{p.caption}</p>}
              <form method="POST" enctype="application/x-www-form-urlencoded" class="gallery-delete-form">
                <input type="hidden" name="_action" value="a_takim_gallery_delete" />
                <input type="hidden" name="id" value={p.id} />
                <button type="submit" class="btn-delete btn-delete-small">Sil</button>
              </form>
            </div>
          ))}
        </div>
      )}

      <form method="POST" enctype="multipart/form-data" class="match-form new-match" style="margin-top: 1.4rem;">
        <input type="hidden" name="_action" value="a_takim_gallery_add" />
        <p class="slot-label">+ Yeni Fotoğraf Ekle</p>

        <div class="form-row">
          <label>Açıklama (isteğe bağlı)
            <input name="caption" placeholder="Fotoğraf açıklaması..." />
          </label>
          <label>Sıra
            <input type="number" name="sort_order" value="99" min="0" />
          </label>
        </div>

        <div class="form-row">
          <label>Fotoğraf — Cihazdan Yükle
            <div class="file-wrap">
              <input type="file" name="image_file" accept="image/*" class="file-input" />
            </div>
          </label>
          <label>veya Görsel URL
            <input name="image_url" placeholder="https://..." />
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">Fotoğraf Ekle</button>
        </div>
      </form>
    </section>

    <!-- ── PİLOT TAKIM HERO ── -->
    <section class="panel">
      <h2>Pilot Takım — Hero Görseli</h2>
      <form method="POST" enctype="multipart/form-data" class="match-form" style="border-bottom:none;margin-bottom:0;padding-bottom:0">
        <input type="hidden" name="_action" value="pilot_hero_save" />

        <div class="form-row">
          <label>Görsel — Cihazdan Yükle
            <div class="file-wrap">
              {pilotHeroImage && <img src={pilotHeroImage} class="news-preview" alt="pilot hero" />}
              <input type="file" name="image_file" accept="image/*" class="file-input" />
            </div>
          </label>
          <label>veya Görsel URL
            <input name="image_url" value={pilotHeroImage ?? ''} placeholder="https://..." />
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">Kaydet</button>
        </div>
      </form>
    </section>

    <!-- ── PİLOT TAKIM GALERİSİ ── -->
    <section class="panel">
      <h2>Pilot Takım Galerisi</h2>

      {pilotPhotos.length > 0 && (
        <div class="gallery-admin-grid">
          {pilotPhotos.map(p => (
            <div class="gallery-admin-item">
              <img src={p.image_url} alt={p.caption ?? ''} class="gallery-thumb" />
              {p.caption && <p class="gallery-admin-caption">{p.caption}</p>}
              <form method="POST" enctype="application/x-www-form-urlencoded" class="gallery-delete-form">
                <input type="hidden" name="_action" value="pilot_gallery_delete" />
                <input type="hidden" name="id" value={p.id} />
                <button type="submit" class="btn-delete btn-delete-small">Sil</button>
              </form>
            </div>
          ))}
        </div>
      )}

      <form method="POST" enctype="multipart/form-data" class="match-form new-match" style="margin-top: 1.4rem;">
        <input type="hidden" name="_action" value="pilot_gallery_add" />
        <p class="slot-label">+ Yeni Fotoğraf Ekle</p>

        <div class="form-row">
          <label>Açıklama (isteğe bağlı)
            <input name="caption" placeholder="Fotoğraf açıklaması..." />
          </label>
          <label>Sıra
            <input type="number" name="sort_order" value="99" min="0" />
          </label>
        </div>

        <div class="form-row">
          <label>Fotoğraf — Cihazdan Yükle
            <div class="file-wrap">
              <input type="file" name="image_file" accept="image/*" class="file-input" />
            </div>
          </label>
          <label>veya Görsel URL
            <input name="image_url" placeholder="https://..." />
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">Fotoğraf Ekle</button>
        </div>
      </form>
    </section>

    <!-- ── AKADEMİ GALERİSİ ── -->
    <section class="panel">
      <h2>Akademi Galerisi</h2>

      <!-- Mevcut fotoğraflar -->
      {galleryPhotos.length > 0 && (
        <div class="gallery-admin-grid">
          {galleryPhotos.map(p => (
            <div class="gallery-admin-item">
              <img src={p.image_url} alt={p.caption ?? ''} class="gallery-thumb" />
              {p.caption && <p class="gallery-admin-caption">{p.caption}</p>}
              <form method="POST" enctype="application/x-www-form-urlencoded" class="gallery-delete-form">
                <input type="hidden" name="_action" value="gallery_delete" />
                <input type="hidden" name="id" value={p.id} />
                <button type="submit" class="btn-delete btn-delete-small">Sil</button>
              </form>
            </div>
          ))}
        </div>
      )}

      <!-- Yeni fotoğraf ekle -->
      <form method="POST" enctype="multipart/form-data" class="match-form new-match" style="margin-top: 1.4rem;">
        <input type="hidden" name="_action" value="gallery_add" />
        <p class="slot-label">+ Yeni Fotoğraf Ekle</p>

        <div class="form-row">
          <label>Açıklama (isteğe bağlı)
            <input name="caption" placeholder="Fotoğraf açıklaması..." />
          </label>
          <label>Sıra
            <input type="number" name="sort_order" value="99" min="0" />
          </label>
        </div>

        <div class="form-row">
          <label>Fotoğraf — Cihazdan Yükle
            <div class="file-wrap">
              <input type="file" name="image_file" accept="image/*" class="file-input" />
            </div>
          </label>
          <label>veya Görsel URL
            <input name="image_url" placeholder="https://..." />
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">Fotoğraf Ekle</button>
        </div>
      </form>
    </section>

  </main>
</body>
</html>

