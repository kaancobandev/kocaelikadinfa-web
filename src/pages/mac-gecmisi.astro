---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { supabase, type Match } from '../lib/supabase';

const { data } = await supabase
  .from('matches')
  .select('*')
  .order('id', { ascending: false });

const matches: Match[] = data ?? [];

const u15Matches = matches.filter(m => m.badge === 'U15');
const u13Matches = matches.filter(m => m.badge === 'U13');
const otherMatches = matches.filter(m => m.badge !== 'U15' && m.badge !== 'U13');

function result(m: Match): 'win' | 'draw' | 'loss' | null {
  // KKFK'nın ev sahibi veya deplasman olduğunu home_name ile anlıyoruz
  const homeIsKKFK = m.home_name.toLowerCase().includes('kkfk');
  if (m.score_home === m.score_away) return 'draw';
  if (homeIsKKFK) return m.score_home > m.score_away ? 'win' : 'loss';
  return m.score_away > m.score_home ? 'win' : 'loss';
}

const resultLabel = { win: 'G', draw: 'B', loss: 'M', null: '–' } as const;
const resultClass = { win: 'win', draw: 'draw', loss: 'loss', null: '' } as const;

function initials(name: string) {
  return name.split(' ').map(w => w[0]).slice(0, 2).join('').toUpperCase();
}

const TR_MONTHS = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
function formatDate(d: string) {
  const m = d.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!m) return d;
  return `${parseInt(m[3])} ${TR_MONTHS[parseInt(m[2]) - 1]} ${m[1]}`;
}

// Özet istatistik
function stats(list: Match[]) {
  const w = list.filter(m => result(m) === 'win').length;
  const d = list.filter(m => result(m) === 'draw').length;
  const l = list.filter(m => result(m) === 'loss').length;
  const gf = list.reduce((s, m) => {
    return s + (m.home_name.toLowerCase().includes('kkfk') ? m.score_home : m.score_away);
  }, 0);
  const ga = list.reduce((s, m) => {
    return s + (m.home_name.toLowerCase().includes('kkfk') ? m.score_away : m.score_home);
  }, 0);
  return { w, d, l, gf, ga };
}
---

<Layout title="Maç Geçmişi — Kocaeli Kadın FA">
  <Navbar />

  <main class="mg-page">

    <!-- Hero -->
    <section class="page-hero">
      <div class="page-hero-inner">
        <span class="tag">Sezon 2025–26</span>
        <h1>Maç<br /><span>Geçmişi</span></h1>
        <p>Tüm maçlarımızın sonuçları, skorlar ve karşılaştığımız takımlar.</p>
      </div>
    </section>

    <!-- U15 Takım -->
    {u15Matches.length > 0 && (() => {
      return (
        <section class="group-section">
          <div class="group-header">
            <div class="group-title-wrap">
              <span class="group-badge">U15</span>
              <h2>U15 Maçları</h2>
            </div>
          </div>

          <div class="matches-list">
            {u15Matches.map(m => {
              const r = result(m);
              return (
                <div class="match-card">
                  <div class="match-meta-left">
                    <span class="match-date">{formatDate(m.match_date)}</span>
                  </div>

                  <div class="match-teams">
                    <div class="team-side home">
                      <div class="team-logo-wrap">
                        {m.home_logo
                          ? <img src={m.home_logo} alt={m.home_name} class="team-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                          : null
                        }
                        <span class="team-logo-fallback" style={m.home_logo ? 'display:none' : 'display:flex'}>
                          {initials(m.home_name)}
                        </span>
                      </div>
                      <span class="team-name">{m.home_name}</span>
                    </div>

                    <div class="score-center">
                      <span class="score-big">{m.score_home}</span>
                      <span class="score-sep">–</span>
                      <span class="score-big">{m.score_away}</span>
                    </div>

                    <div class="team-side away">
                      <div class="team-logo-wrap">
                        {m.away_logo
                          ? <img src={m.away_logo} alt={m.away_name} class="team-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                          : null
                        }
                        <span class="team-logo-fallback" style={m.away_logo ? 'display:none' : 'display:flex'}>
                          {initials(m.away_name)}
                        </span>
                      </div>
                      <span class="team-name">{m.away_name}</span>
                    </div>
                  </div>

                  <div class="match-result">
                    <span class={`result-badge ${r ?? ''}`}>
                      {resultLabel[r ?? 'null']}
                    </span>
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      );
    })()}

    <!-- U13 Takım -->
    {u13Matches.length > 0 && (() => {
      return (
        <section class="group-section alt">
          <div class="group-header">
            <div class="group-title-wrap">
              <span class="group-badge">U13</span>
              <h2>U13 Maçları</h2>
            </div>
          </div>

          <div class="matches-list">
            {u13Matches.map(m => {
              const r = result(m);
              return (
                <div class="match-card">
                  <div class="match-meta-left">
                    <span class="match-date">{formatDate(m.match_date)}</span>
                  </div>

                  <div class="match-teams">
                    <div class="team-side home">
                      <div class="team-logo-wrap">
                        {m.home_logo
                          ? <img src={m.home_logo} alt={m.home_name} class="team-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                          : null
                        }
                        <span class="team-logo-fallback" style={m.home_logo ? 'display:none' : 'display:flex'}>
                          {initials(m.home_name)}
                        </span>
                      </div>
                      <span class="team-name">{m.home_name}</span>
                    </div>

                    <div class="score-center">
                      <span class="score-big">{m.score_home}</span>
                      <span class="score-sep">–</span>
                      <span class="score-big">{m.score_away}</span>
                    </div>

                    <div class="team-side away">
                      <div class="team-logo-wrap">
                        {m.away_logo
                          ? <img src={m.away_logo} alt={m.away_name} class="team-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                          : null
                        }
                        <span class="team-logo-fallback" style={m.away_logo ? 'display:none' : 'display:flex'}>
                          {initials(m.away_name)}
                        </span>
                      </div>
                      <span class="team-name">{m.away_name}</span>
                    </div>
                  </div>

                  <div class="match-result">
                    <span class={`result-badge ${r ?? ''}`}>
                      {resultLabel[r ?? 'null']}
                    </span>
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      );
    })()}

    {otherMatches.length > 0 && (() => {
      return (
        <section class="group-section">
          <div class="group-header">
            <div class="group-title-wrap">
              <span class="group-badge">Diğer</span>
              <h2>Diğer Maçlar</h2>
            </div>
          </div>

          <div class="matches-list">
            {otherMatches.map(m => {
              const r = result(m);
              return (
                <div class="match-card">
                  <div class="match-meta-left">
                    <span class="match-date">{formatDate(m.match_date)}</span>
                  </div>

                  <div class="match-teams">
                    <div class="team-side home">
                      <div class="team-logo-wrap">
                        {m.home_logo
                          ? <img src={m.home_logo} alt={m.home_name} class="team-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                          : null
                        }
                        <span class="team-logo-fallback" style={m.home_logo ? 'display:none' : 'display:flex'}>
                          {initials(m.home_name)}
                        </span>
                      </div>
                      <span class="team-name">{m.home_name}</span>
                    </div>

                    <div class="score-center">
                      <span class="score-big">{m.score_home}</span>
                      <span class="score-sep">–</span>
                      <span class="score-big">{m.score_away}</span>
                    </div>

                    <div class="team-side away">
                      <div class="team-logo-wrap">
                        {m.away_logo
                          ? <img src={m.away_logo} alt={m.away_name} class="team-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                          : null
                        }
                        <span class="team-logo-fallback" style={m.away_logo ? 'display:none' : 'display:flex'}>
                          {initials(m.away_name)}
                        </span>
                      </div>
                      <span class="team-name">{m.away_name}</span>
                    </div>
                  </div>

                  <div class="match-result">
                    <span class={`result-badge ${r ?? ''}`}>
                      {resultLabel[r ?? 'null']}
                    </span>
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      );
    })()}

    {matches.length === 0 && (
      <div class="empty-state">
        <p>Henüz maç sonucu eklenmemiş.</p>
        <a href="/admin/dashboard" class="btn-primary">Admin Paneline Git</a>
      </div>
    )}

  </main>

  <Footer />
</Layout>

<style>
  .mg-page { padding-top: var(--nav-h); }

  /* ── Hero ── */
  .page-hero {
    min-height: 40vh;
    display: flex;
    align-items: center;
    background:
      radial-gradient(ellipse 60% 80% at 50% 50%, rgba(26,122,46,0.20) 0%, transparent 65%),
      linear-gradient(160deg, #0d1a0f 0%, var(--black) 60%);
    padding: 5rem 8%;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(26,122,46,0.05) 80px, rgba(26,122,46,0.05) 81px),
      repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(26,122,46,0.05) 80px, rgba(26,122,46,0.05) 81px);
    pointer-events: none;
  }
  .page-hero-inner { position: relative; max-width: 680px; }
  .tag {
    display: inline-block;
    font-size: .7rem; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; color: var(--green-bright); margin-bottom: 1rem;
  }
  .page-hero h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 900; line-height: 1.05; letter-spacing: -2px; margin-bottom: 1.2rem;
  }
  .page-hero h1 span {
    background: linear-gradient(135deg, var(--green-bright) 0%, #5dde7c 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .page-hero p { font-size: 1rem; color: var(--text-muted); max-width: 420px; }

  /* ── Grup bölümü ── */
  .group-section {
    padding: 4rem 8%;
    background: var(--black);
    border-top: 1px solid var(--border);
  }
  .group-section.alt { background: var(--dark); }

  .group-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .group-title-wrap { display: flex; flex-direction: column; gap: .5rem; }
  .group-badge {
    display: inline-block;
    background: var(--green);
    color: #fff;
    font-size: .68rem; font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; padding: .25rem .8rem; border-radius: 50px;
    width: fit-content;
  }
  .group-title-wrap h2 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 900; }

  /* Özet bar */
  .summary-bar { display: flex; gap: 1.2rem; flex-wrap: wrap; }
  .summary-item { display: flex; flex-direction: column; align-items: center; gap: .2rem; }
  .s-num { font-size: 1.6rem; font-weight: 900; color: var(--text); line-height: 1; }
  .s-lbl { font-size: .65rem; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text-muted); }
  .win-color  { color: var(--green-bright) !important; }
  .draw-color { color: #d4d452 !important; }
  .loss-color { color: #e05555 !important; }

  /* ── Maç kartları ── */
  .matches-list { display: flex; flex-direction: column; gap: .8rem; }

  .match-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.4rem;
    display: grid;
    grid-template-columns: 140px 1fr 56px;
    align-items: center;
    gap: 1rem;
    transition: border-color .2s, background .2s;
  }
  .match-card:hover { border-color: var(--green); background: #1a1a1a; }

  @media (max-width: 640px) {
    .match-card {
      grid-template-columns: 1fr;
      gap: .5rem;
      padding: .8rem 1rem;
    }
    .match-meta-left {
      flex-direction: row;
      align-items: center;
      gap: .6rem;
      flex-wrap: wrap;
    }
    .match-teams { gap: .5rem; }
    .team-side {
      flex-direction: column;
      align-items: center;
      gap: .25rem;
      min-width: 0;
    }
    .team-side.home,
    .team-side.away { justify-content: center; }
    .team-name {
      font-size: .72rem;
      white-space: normal;
      max-width: 90px;
      text-align: center;
      line-height: 1.25;
    }
    .match-result { display: none; }
  }

  .match-meta-left { display: flex; flex-direction: column; gap: .3rem; }
  .match-date   { font-size: .8rem; font-weight: 700; color: var(--text); }

  /* Takımlar + skor */
  .match-teams {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
  }

  .team-side {
    display: flex;
    align-items: center;
    gap: .6rem;
    flex: 1;
  }
  .team-side.home { justify-content: flex-end; }
  .team-side.away { justify-content: flex-start; }

  .team-logo-wrap {
    width: 40px; height: 40px; flex-shrink: 0;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.03);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .team-logo { width: 100%; height: 100%; object-fit: contain; padding: 4px; }
  .team-logo-fallback {
    font-size: .65rem; font-weight: 900;
    color: var(--green-bright); letter-spacing: .5px;
    align-items: center; justify-content: center;
  }
  .team-name {
    font-size: .85rem;
    font-weight: 700;
    white-space: normal;
    word-break: break-word;
    line-height: 1.3;
  }

  .score-center {
    display: flex; align-items: center; gap: .4rem; flex-shrink: 0;
  }
  .score-big { font-size: 1.6rem; font-weight: 900; color: var(--green-bright); line-height: 1; }
  .score-sep { font-size: 1.2rem; color: var(--text-muted); }

  /* Sonuç */
  .match-result { display: flex; justify-content: center; }
  .result-badge {
    width: 36px; height: 36px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .78rem; font-weight: 900;
  }
  .result-badge.win  { background: rgba(34,150,58,.2);  color: var(--green-bright); }
  .result-badge.draw { background: rgba(200,200,0,.15); color: #d4d452; }
  .result-badge.loss { background: rgba(200,40,40,.15); color: #e05555; }

  /* Boş durum */
  .empty-state {
    padding: 6rem 8%;
    text-align: center;
    color: var(--text-muted);
    display: flex; flex-direction: column; align-items: center; gap: 1.5rem;
  }
</style>
