---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Aramıza Katıl — Kocaeli Kadın Futbol Kulübü"
  description="Kocaeli Kadın Futbol Kulübü ailesine katıl! Seçmelere başvur, antrenmanlara katıl. Kadın futbolu kariyerine Kocaeli'de başla."
>
  <Navbar />

  <main class="join-page">

    <section class="join-hero">
      <div class="join-hero-inner">
        <span class="tag">Bize Katıl</span>
        <h1>Aramıza<br /><span>Katıl</span></h1>
        <p>Kocaeli Kadın Futbol Kulübü ailesine katılmak için aşağıdaki seçeneklerden birini kullanabilirsin.</p>
      </div>
    </section>

    <section class="join-options">
      <div class="options-grid">

        <!-- Online Başvuru -->
        <a
          href="https://kocaelikadinfk.sporakademik.com/OnKayit"
          target="_blank"
          rel="noopener noreferrer"
          class="option-card"
        >
          <div class="option-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <div class="option-body">
            <h2>Online Başvuru</h2>
            <p>Sporcu ön kayıt formunu doldurarak hemen başvurunu tamamla.</p>
          </div>
          <div class="option-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </div>
        </a>

        <!-- WhatsApp İletişim -->
        <a
          href="https://wa.me/905326944509"
          target="_blank"
          rel="noopener noreferrer"
          class="option-card option-whatsapp"
        >
          <div class="option-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
            </svg>
          </div>
          <div class="option-body">
            <h2>WhatsApp ile İletişim</h2>
            <p>Sorularını sormak ya da bilgi almak için bize WhatsApp'tan ulaş.</p>
            <span class="phone-num">+90 532 694 45 09</span>
          </div>
          <div class="option-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </div>
        </a>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .join-hero {
    min-height: 40vh;
    display: flex;
    align-items: center;
    background:
      radial-gradient(ellipse 60% 80% at 50% 50%, rgba(26,122,46,0.22) 0%, transparent 65%),
      linear-gradient(160deg, #0d1a0f 0%, var(--black) 60%);
    padding: 5rem 8%;
    position: relative;
    overflow: hidden;
  }
  .join-hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(26,122,46,0.05) 80px, rgba(26,122,46,0.05) 81px),
      repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(26,122,46,0.05) 80px, rgba(26,122,46,0.05) 81px);
    pointer-events: none;
  }
  .join-hero-inner { position: relative; max-width: 680px; }

  .tag {
    display: inline-block;
    font-size: .7rem; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; color: var(--green-bright); margin-bottom: 1rem;
  }
  .join-hero h1 {
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 900; line-height: 1.05; letter-spacing: -2px; margin-bottom: 1.2rem;
  }
  .join-hero h1 span {
    background: linear-gradient(135deg, var(--green-bright) 0%, #5dde7c 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .join-hero p { font-size: 1rem; color: var(--text-muted); max-width: 440px; }

  /* ── Seçenekler ── */
  .join-options {
    padding: 5rem 8%;
    background: var(--dark);
    border-top: 1px solid var(--border);
    min-height: 40vh;
    display: flex;
    align-items: center;
  }

  .options-grid {
    width: 100%;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .option-card {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem 2rem;
    text-decoration: none;
    color: var(--text);
    transition: border-color .25s, background .25s, transform .2s;
  }
  .option-card:hover {
    border-color: var(--green-bright);
    background: #111;
    transform: translateY(-3px);
  }

  .option-icon {
    width: 64px; height: 64px; flex-shrink: 0;
    border-radius: 16px;
    background: rgba(44,184,74,0.1);
    border: 1px solid rgba(44,184,74,0.2);
    display: flex; align-items: center; justify-content: center;
    color: var(--green-bright);
    transition: background .25s;
  }
  .option-card:hover .option-icon { background: rgba(44,184,74,0.18); }

  .option-whatsapp .option-icon {
    background: rgba(37,211,102,0.1);
    border-color: rgba(37,211,102,0.25);
    color: #25d366;
  }
  .option-card.option-whatsapp:hover { border-color: #25d366; }
  .option-card.option-whatsapp:hover .option-icon { background: rgba(37,211,102,0.18); }

  .option-body {
    flex: 1;
    min-width: 0;
  }
  .option-body h2 {
    font-size: 1.2rem; font-weight: 900;
    margin-bottom: .5rem;
  }
  .option-body p {
    font-size: .88rem; color: var(--text-muted);
    line-height: 1.6;
  }
  .phone-num {
    display: inline-block;
    margin-top: .5rem;
    font-size: .9rem;
    font-weight: 700;
    color: #25d366;
    letter-spacing: .5px;
  }

  .option-arrow {
    flex-shrink: 0;
    color: var(--text-muted);
    transition: color .25s, transform .25s;
  }
  .option-card:hover .option-arrow {
    color: var(--green-bright);
    transform: translateX(4px);
  }
  .option-card.option-whatsapp:hover .option-arrow { color: #25d366; }

  @media (max-width: 600px) {
    .option-card { padding: 1.4rem 1.2rem; gap: 1rem; }
    .option-icon { width: 52px; height: 52px; border-radius: 12px; }
    .option-icon svg { width: 24px; height: 24px; }
    .option-body h2 { font-size: 1rem; }
    .option-arrow { display: none; }
  }
</style>
