---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { supabase, type NewsItem } from '../../lib/supabase';
import { img, imgSet } from '../../lib/img';
import { newsPath, idFromSlug, excerpt, paragraphs, linkify, formatDate, isoDate } from '../../lib/news';

const { slug = '' } = Astro.params;
const id = idFromSlug(slug);

let article: NewsItem | null = null;
if (id !== null) {
  const { data } = await supabase.from('news').select('*').eq('id', id).single();
  article = data ?? null;
}

// Haber yoksa 404 sayfasını göster
if (!article) {
  return Astro.rewrite('/404');
}

// Başlık değiştiyse kanonik adrese kalıcı yönlendir (SEO)
const canonical = newsPath(article);
if (`/haberler/${slug}` !== canonical) {
  return Astro.redirect(canonical, 301);
}

// Diğer haberler
const { data: othersData } = await supabase
  .from('news')
  .select('*')
  .neq('id', article.id)
  .order('id', { ascending: false })
  .limit(3);
const others: NewsItem[] = othersData ?? [];

const body = paragraphs(article.description);
const özet = excerpt(article.description, 160);
const tarih = formatDate(article.published_at);
const tarihISO = isoDate(article.published_at);

const siteUrl = Astro.site?.href ?? 'https://kocaelikadinfa.com/';
const fullUrl = new URL(canonical, siteUrl).href;
const paylasMetni = `${article.title} — Kocaeli Kadın Futbol Kulübü`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: article.title,
  description: özet,
  ...(article.image_url && { image: [article.image_url] }),
  ...(tarihISO && { datePublished: tarihISO }),
  mainEntityOfPage: { '@type': 'WebPage', '@id': fullUrl },
  author:    { '@type': 'Organization', name: 'Kocaeli Kadın Futbol Kulübü', url: siteUrl },
  publisher: {
    '@type': 'Organization',
    name: 'Kocaeli Kadın Futbol Kulübü',
    logo: { '@type': 'ImageObject', url: new URL('/logo.jpeg', siteUrl).href },
  },
};
---

<Layout
  title={`${article.title} — Kocaeli Kadın Futbol Kulübü`}
  description={özet || 'Kocaeli Kadın Futbol Kulübü haberi.'}
  image={article.image_url ?? '/logo.jpeg'}
>
  <Navbar />

  <main class="article-page">
    <article>
      <!-- Başlık -->
      <header class="article-hero">
        <div class="article-hero-inner">
          <a href="/haberler" class="back-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            Tüm Haberler
          </a>

          <span class="article-tag">Haber</span>
          <h1>{article.title}</h1>
          {tarih && <time class="article-date" datetime={tarihISO}>{tarih}</time>}
        </div>
      </header>

      <!-- Görsel -->
      {article.image_url && (
        <div class="article-media">
          <div class="article-media-bg" ></div>
          <img
            src={img(article.image_url, 1200)}
            srcset={imgSet(article.image_url, [600, 1200, 1600])}
            sizes="(max-width: 900px) 100vw, 900px"
            alt={article.title}
            fetchpriority="high"
          />
        </div>
      )}

      <!-- Metin -->
      <div class="article-body">
        {body.length > 0
          ? body.map(p => <p set:html={linkify(p)}></p>)
          : <p class="article-empty">Bu haberin içeriği henüz eklenmemiş.</p>
        }

        <!-- Paylaş -->
        <div class="share">
          <span class="share-label">Paylaş</span>
          <div class="share-btns">
            <a class="share-btn" aria-label="WhatsApp'ta paylaş" target="_blank" rel="noopener noreferrer"
               href={`https://wa.me/?text=${encodeURIComponent(paylasMetni + ' ' + fullUrl)}`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            </a>
            <a class="share-btn" aria-label="X'te paylaş" target="_blank" rel="noopener noreferrer"
               href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(paylasMetni)}&url=${encodeURIComponent(fullUrl)}`}>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.743l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a class="share-btn" aria-label="Facebook'ta paylaş" target="_blank" rel="noopener noreferrer"
               href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(fullUrl)}`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.52 1.5-3.91 3.77-3.91 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.89h2.78l-.44 2.91h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94z"/></svg>
            </a>
            <button type="button" class="share-btn" id="copy-link" data-url={fullUrl} aria-label="Bağlantıyı kopyala">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
            </button>
            <span class="copy-done" id="copy-done" role="status">Kopyalandı</span>
          </div>
        </div>
      </div>
    </article>

    <!-- Diğer haberler -->
    {others.length > 0 && (
      <section class="more">
        <h2 class="more-title">Diğer Haberler</h2>
        <div class="more-grid">
          {others.map(n => (
            <a href={newsPath(n)} class="more-card">
              <div class="more-img">
                <div class="more-img-bg" ></div>
                <img
                  src={img(n.image_url, 600)}
                  srcset={imgSet(n.image_url, [400, 800])}
                  sizes="(max-width: 900px) 100vw, 33vw"
                  alt={n.title}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="more-body">
                {formatDate(n.published_at) && (
                  <time class="more-date" datetime={isoDate(n.published_at)}>{formatDate(n.published_at)}</time>
                )}
                <h3>{n.title}</h3>
                <p>{excerpt(n.description, 90)}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

<style>
  .article-page { background: var(--black); }

  /* ── Başlık ── */
  .article-hero {
    background:
      radial-gradient(ellipse 60% 80% at 50% 50%, rgba(26,122,46,0.18) 0%, transparent 65%),
      linear-gradient(160deg, #0d1a0f 0%, var(--black) 60%);
    padding: 3.5rem 5% 3rem;
    border-bottom: 1px solid var(--border);
  }
  .article-hero-inner { max-width: 820px; margin: 0 auto; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 1.6rem;
    transition: color .2s, gap .2s;
  }
  .back-link:hover { color: var(--green-bright); gap: .7rem; }
  .back-link:focus-visible { outline: 2px solid var(--green-bright); outline-offset: 3px; border-radius: 4px; }

  .article-tag {
    display: block;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--green-bright);
    margin-bottom: .8rem;
  }
  .article-hero h1 {
    font-size: clamp(1.7rem, 4.2vw, 2.9rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -.5px;
    margin-bottom: 1rem;
  }
  .article-date {
    font-size: .85rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  /* ── Görsel ── */
  .article-media {
    position: relative;
    max-width: 900px;
    margin: 2.5rem auto 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #0a0a0a;
  }
  .article-media-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #141814 0%, #0a0d0a 100%);
  }
  /* Haber görseli tam görünsün ama ekranı ele geçirmesin */
  .article-media img {
    position: relative;
    display: block;
    width: 100%;
    height: auto;
    min-height: var(--media-min-h);
    max-height: min(70vh, 620px);
    object-fit: contain;
  }
  @media (max-width: 600px) {
    .article-media img { max-height: 60vh; }
  }
  @media (max-width: 900px) { .article-media { margin-inline: 5%; border-radius: 10px; } }

  /* ── Metin ── */
  .article-body {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 5% 4rem;
  }
  .article-body p {
    font-size: 1.05rem;
    line-height: 1.85;
    color: #c8c8c8;
    margin-bottom: 1.4rem;
  }
  .article-body p:last-of-type { margin-bottom: 0; }
  .article-empty { color: var(--text-muted); font-style: italic; }

  .article-body :global(.news-link) {
    color: #4da6ff;
    text-decoration: underline;
    word-break: break-word;
  }
  .article-body :global(.news-link:hover) { color: #80c1ff; }

  /* ── Paylaş ── */
  .share {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 3rem;
    padding-top: 1.8rem;
    border-top: 1px solid var(--border);
  }
  .share-label {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .share-btns { display: flex; align-items: center; gap: .5rem; }

  .share-btn {
    width: 38px; height: 38px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.03);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
    transition: color .25s, border-color .25s, background .25s, transform .2s;
  }
  .share-btn:hover {
    color: var(--green-bright);
    border-color: var(--green-bright);
    background: rgba(44,184,74,0.08);
    transform: translateY(-2px);
  }
  .share-btn:focus-visible { outline: 2px solid var(--green-bright); outline-offset: 2px; }

  .copy-done {
    font-size: .75rem;
    font-weight: 700;
    color: var(--green-bright);
    opacity: 0;
    transition: opacity .2s;
  }
  .copy-done.show { opacity: 1; }

  /* ── Diğer haberler ── */
  .more {
    padding: 3.5rem 5% 5rem;
    background: var(--dark);
    border-top: 1px solid var(--border);
  }
  .more-title {
    max-width: 1160px;
    margin: 0 auto 2rem;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--green-bright);
  }
  .more-grid {
    max-width: 1160px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }
  @media (max-width: 900px) { .more-grid { grid-template-columns: 1fr; } }

  .more-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    transition: border-color .25s, transform .2s, box-shadow .25s;
  }
  .more-card:hover {
    border-color: var(--green);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(13,77,30,0.18);
  }
  .more-card:focus-visible { outline: 2px solid var(--green-bright); outline-offset: 3px; }

  .more-img {
    position: relative;
    aspect-ratio: 16 / 10;
    max-height: 260px;
    overflow: hidden;
    background: #0a0a0a;
  }
  .more-img-bg {
    position: absolute; inset: 0;
    background: linear-gradient(160deg, #141814 0%, #0a0d0a 100%);
  }
  .more-img img {
    position: relative;
    width: 100%; height: 100%;
    object-fit: contain;
    display: block;
  }

  .more-body { padding: 1.1rem 1.2rem 1.4rem; display: flex; flex-direction: column; gap: .5rem; }
  .more-date { font-size: .72rem; font-weight: 700; color: var(--green-bright); letter-spacing: .5px; }
  .more-body h3 {
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.35;
    color: var(--text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .more-body p { font-size: .82rem; color: var(--text-muted); line-height: 1.55; }
</style>

<script>
  const btn  = document.getElementById('copy-link');
  const done = document.getElementById('copy-done');

  btn?.addEventListener('click', async () => {
    const url = btn.getAttribute('data-url') ?? location.href;
    try {
      await navigator.clipboard.writeText(url);
    } catch {
      const tmp = document.createElement('input');
      tmp.value = url;
      document.body.appendChild(tmp);
      tmp.select();
      document.execCommand('copy');
      tmp.remove();
    }
    done?.classList.add('show');
    setTimeout(() => done?.classList.remove('show'), 1800);
  });
</script>
