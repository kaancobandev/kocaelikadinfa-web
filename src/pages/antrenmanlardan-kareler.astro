---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { supabase, type AntrenmanGaleriItem } from '../lib/supabase';

const { data } = await supabase
  .from('antrenman_galeri')
  .select('*')
  .order('sort_order', { ascending: true });

const items: AntrenmanGaleriItem[] = data ?? [];

function youtubeId(url: string): string | null {
  const m = url.match(/(?:v=|youtu\.be\/|embed\/|shorts\/)([A-Za-z0-9_-]{11})/);
  return m ? m[1] : null;
}

function isYoutube(url: string): boolean {
  return /youtu(\.be|be\.com)/i.test(url);
}
---

<Layout
  title="Antrenmanlardan Kareler — Kocaeli Kadın Futbol Kulübü"
  description="Kocaeli Kadın Futbol Kulübü antrenmanlarından fotoğraf ve videolar. Sahadaki çalışmalarımıza ve takım ruhumuza yakından bakın."
>
  <Navbar />

  <main>

    <!-- Hero -->
    <section class="page-hero">
      <div class="page-hero-inner">
        <span class="tag">Videolar & Fotoğraflar</span>
        <h1>Antrenmanlardan<br /><span>Kareler</span></h1>
        <p>Sahadan, antrenmandan ve kulübümüzün özel anlarından görüntüler.</p>
      </div>
    </section>

    <!-- İçerik -->
    {items.length > 0 ? (
      <section class="galeri-section">
        <div class="galeri-grid">
          {items.map(item => (
            <div class="galeri-card">
              {isYoutube(item.media_url) ? (
                <div class="yt-wrap">
                  <div class="yt-frame-wrap">
                    <iframe
                      src={`https://www.youtube.com/embed/${youtubeId(item.media_url)}`}
                      title={item.caption ?? ''}
                      frameborder="0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    ></iframe>
                  </div>
                  {item.caption && <p class="card-caption">{item.caption}</p>}
                </div>
              ) : (
                <button class="img-btn" data-src={item.media_url} data-caption={item.caption ?? ''} aria-label={item.caption ?? 'Fotoğraf'}>
                  <img src={item.media_url} alt={item.caption ?? ''} loading="lazy" />
                  <span class="img-overlay">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                  </span>
                  {item.caption && <span class="card-caption">{item.caption}</span>}
                </button>
              )}
            </div>
          ))}
        </div>
      </section>
    ) : (
      <div class="empty-state">
        <p>Henüz içerik eklenmemiş.</p>
      </div>
    )}

  </main>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true">
    <button id="lb-close" class="lb-close" aria-label="Kapat">✕</button>
    <img id="lb-img" src="" alt="" />
    <p id="lb-caption" class="lb-caption"></p>
  </div>

  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .page-hero {
    min-height: 38vh;
    display: flex;
    align-items: center;
    background:
      radial-gradient(ellipse 60% 80% at 50% 50%, rgba(26,122,46,0.20) 0%, transparent 65%),
      linear-gradient(160deg, #0d1a0f 0%, var(--black) 60%);
    padding: 5rem 8%;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(26,122,46,0.05) 80px, rgba(26,122,46,0.05) 81px),
      repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(26,122,46,0.05) 80px, rgba(26,122,46,0.05) 81px);
    pointer-events: none;
  }
  .page-hero-inner { position: relative; max-width: 680px; }
  .tag {
    display: inline-block;
    font-size: .7rem; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; color: var(--green-bright); margin-bottom: 1rem;
  }
  .page-hero h1 {
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 900; line-height: 1.05; letter-spacing: -2px; margin-bottom: 1.2rem;
  }
  .page-hero h1 span {
    background: linear-gradient(135deg, var(--green-bright) 0%, #5dde7c 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .page-hero p { font-size: 1rem; color: var(--text-muted); max-width: 420px; }

  /* ── Grid ── */
  .galeri-section {
    padding: 4rem 5% 6rem;
    background: var(--black);
    border-top: 1px solid var(--border);
  }

  .galeri-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  @media (max-width: 960px) { .galeri-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .galeri-grid { grid-template-columns: 1fr; } }

  .galeri-card {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--card-bg);
    transition: border-color .25s, transform .2s, box-shadow .25s;
  }
  .galeri-card:hover {
    border-color: var(--green);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(13,77,30,0.18);
  }

  /* YouTube */
  .yt-wrap { display: flex; flex-direction: column; }
  .yt-frame-wrap {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }
  .yt-frame-wrap iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: none;
  }

  /* Fotoğraf */
  .img-btn {
    position: relative;
    display: block;
    width: 100%;
    border: none;
    background: none;
    cursor: pointer;
    overflow: hidden;
    padding: 0;
  }
  .img-btn img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    transition: transform .35s;
  }
  .img-btn:hover img { transform: scale(1.04); }

  .img-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .25s;
  }
  .img-overlay svg {
    width: 44px; height: 44px;
    color: #fff; opacity: 0;
    transition: opacity .25s;
  }
  .img-btn:hover .img-overlay { background: rgba(0,0,0,.35); }
  .img-btn:hover .img-overlay svg { opacity: 1; }

  .card-caption {
    display: block;
    padding: .65rem .9rem;
    font-size: .8rem;
    color: var(--text-muted);
    background: var(--card-bg);
  }

  /* Boş durum */
  .empty-state {
    padding: 6rem 8%;
    text-align: center;
    color: var(--text-muted);
  }

  /* Lightbox */
  .lightbox {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,.92);
    z-index: 9000;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
  }
  .lightbox.open { display: flex; }
  .lightbox img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 8px 48px rgba(0,0,0,.6);
  }
  .lb-caption {
    color: rgba(255,255,255,.65);
    font-size: .85rem;
    text-align: center;
    max-width: 600px;
  }
  .lb-close {
    position: fixed;
    top: 1.2rem; right: 1.4rem;
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.15);
    color: #fff;
    font-size: 1.2rem;
    width: 40px; height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s;
    z-index: 9100;
  }
  .lb-close:hover { background: rgba(255,255,255,.2); }
</style>

<script>
  const lightbox  = document.getElementById('lightbox')!;
  const lbImg     = document.getElementById('lb-img')      as HTMLImageElement;
  const lbCaption = document.getElementById('lb-caption')!;
  const lbClose   = document.getElementById('lb-close')!;

  document.querySelectorAll<HTMLButtonElement>('.img-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      lbImg.src             = btn.dataset.src ?? '';
      lbImg.alt             = btn.dataset.caption ?? '';
      lbCaption.textContent = btn.dataset.caption ?? '';
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function close() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  }
  lbClose.addEventListener('click', close);
  lightbox.addEventListener('click', e => { if (e.target === lightbox) close(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
</script>
