---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { supabase, type NewsItem } from '../lib/supabase';

const { data } = await supabase
  .from('news')
  .select('*')
  .order('id', { ascending: false });

const news: NewsItem[] = data ?? [];

const fallbackImg = 'https://images.unsplash.com/photo-1543326727-cf6c39e8f84c?w=800&q=80';
---

<Layout title="Haberler — Kocaeli Kadın Futbol Kulübü">
  <Navbar />

  <main class="haberler-page">

    <!-- Hero -->
    <section class="page-hero">
      <div class="page-hero-inner">
        <span class="tag">Son Dakika</span>
        <h1>Haber<br /><span>Merkezi</span></h1>
        <p>Kulübümüzden son gelişmeler, maç haberleri ve duyurular.</p>
      </div>
    </section>

    <!-- Haberler grid -->
    {news.length > 0 ? (
      <section class="news-section">
        <div class="news-grid">
          {news.map(n => (
            <article class="news-card">
              <div
                class="news-img"
                style={`background-image: url('${n.image_url ?? fallbackImg}')`}
              ></div>
              <div class="news-body">
                <span class="news-tag">Haber</span>
                <h2>{n.title}</h2>
                <p>{n.description}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    ) : (
      <div class="empty-state">
        <p>Henüz haber eklenmemiş.</p>
        <a href="/admin/dashboard" class="btn-primary">Admin Paneline Git</a>
      </div>
    )}

  </main>

  <Footer />
</Layout>

<style>
  .haberler-page { padding-top: var(--nav-h); }

  /* ── Hero ── */
  .page-hero {
    min-height: 38vh;
    display: flex;
    align-items: center;
    background:
      radial-gradient(ellipse 60% 80% at 50% 50%, rgba(26,122,46,0.20) 0%, transparent 65%),
      linear-gradient(160deg, #0d1a0f 0%, var(--black) 60%);
    padding: 5rem 8%;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(26,122,46,0.05) 80px, rgba(26,122,46,0.05) 81px),
      repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(26,122,46,0.05) 80px, rgba(26,122,46,0.05) 81px);
    pointer-events: none;
  }
  .page-hero-inner { position: relative; max-width: 680px; }
  .tag {
    display: inline-block;
    font-size: .7rem; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; color: var(--green-bright); margin-bottom: 1rem;
  }
  .page-hero h1 {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 900; line-height: 1.05; letter-spacing: -2px; margin-bottom: 1.2rem;
  }
  .page-hero h1 span {
    background: linear-gradient(135deg, var(--green-bright) 0%, #5dde7c 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .page-hero p { font-size: 1rem; color: var(--text-muted); max-width: 420px; }

  /* ── Haber Grid ── */
  .news-section {
    padding: 4rem 5%;
    background: var(--black);
    border-top: 1px solid var(--border);
  }

  .news-grid {
    max-width: 1160px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 960px) {
    .news-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .news-grid { grid-template-columns: 1fr; }
  }

  .news-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color .25s, transform .2s, box-shadow .25s;
  }
  .news-card:hover {
    border-color: var(--green);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(13,77,30,0.18);
  }

  .news-img {
    height: 200px;
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .news-body {
    padding: 1.5rem 1.6rem 1.8rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
    flex: 1;
  }

  .news-tag {
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--green-bright);
  }

  .news-body h2 {
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1.35;
    color: var(--text);
  }

  .news-body p {
    font-size: .875rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
  }

  /* ── Boş durum ── */
  .empty-state {
    padding: 6rem 8%;
    text-align: center;
    color: var(--text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .btn-primary {
    background: var(--green);
    color: #fff;
    padding: .7rem 1.6rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: .875rem;
    text-decoration: none;
    transition: background .2s;
  }
  .btn-primary:hover { background: var(--green-mid); }
</style>
