---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import { supabase, type NewsItem } from '../lib/supabase';
import { img, imgSet } from '../lib/img';
import { newsPath, excerpt, formatDate, isoDate } from '../lib/news';

const { data } = await supabase
  .from('news')
  .select('*')
  .order('id', { ascending: false });

const news: NewsItem[] = data ?? [];

const fallbackImg = 'https://images.unsplash.com/photo-1543326727-cf6c39e8f84c?w=800&q=80';
---

<Layout
  title="Haberler — Kocaeli Kadın Futbol Kulübü"
  description="Kocaeli Kadın Futbol Kulübü'nden son dakika haberleri, maç sonuçları ve duyurular. Kulübün güncel gelişmelerini buradan takip edin."
>
  <Navbar />

  <main class="haberler-page">

    <PageHero
      tag="Son Dakika"
      title="Haber"
      accent="Merkezi"
      description="Kulübümüzden son gelişmeler, maç haberleri ve duyurular."
      minHeight="38vh"
    />

    <!-- Haberler grid -->
    {news.length > 0 ? (
      <section class="news-section">
        <div class="news-grid">
          {news.map(n => (
            <article class="news-card">
              <a href={newsPath(n)} class="news-link-wrap">
                <div class="news-img">
                  <div class="news-img-bg"></div>
                  <img
                    class="news-img-fg"
                    src={img(n.image_url, 800) || fallbackImg}
                    srcset={imgSet(n.image_url)}
                    sizes="(max-width: 600px) 100vw, (max-width: 960px) 50vw, 33vw"
                    alt={n.title}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="news-body">
                  <div class="news-meta">
                    <span class="news-tag">Haber</span>
                    {formatDate(n.published_at) && (
                      <time class="news-date" datetime={isoDate(n.published_at)}>{formatDate(n.published_at)}</time>
                    )}
                  </div>
                  <h2>{n.title}</h2>
                  <p>{excerpt(n.description, 170)}</p>
                  <span class="news-more">Devamını Oku →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    ) : (
      <div class="empty-state">
        <p>Henüz haber eklenmemiş.</p>
        <a href="/admin/dashboard" class="btn-primary">Admin Paneline Git</a>
      </div>
    )}

  </main>

  <Footer />
</Layout>

<style>
  /* ── Haber Grid ── */
  .news-section {
    padding: 4rem 5%;
    background: var(--black);
    border-top: 1px solid var(--border);
  }

  .news-grid {
    max-width: 1160px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 960px) {
    .news-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .news-grid { grid-template-columns: 1fr; }
  }

  .news-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color .25s, transform .2s, box-shadow .25s;
  }
  .news-card:hover {
    border-color: var(--green);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(13,77,30,0.18);
  }
  .news-card:focus-within {
    border-color: var(--green-bright);
    outline: 2px solid var(--green-bright);
    outline-offset: 3px;
  }

  /* Kartın tamamı tıklanabilir */
  .news-link-wrap {
    display: flex;
    flex-direction: column;
    flex: 1;
    text-decoration: none;
    color: inherit;
  }
  .news-link-wrap:focus-visible { outline: none; }

  /* Sabit oran, ama tavanla sınırlı: dar kolonlarda kart aşırı uzamıyor */
  .news-img {
    position: relative;
    aspect-ratio: 3 / 4;
    max-height: var(--card-media-max-h);
    overflow: hidden;
    background: #0a0a0a;
    flex-shrink: 0;
  }
  /* Tek kolona düşünce kart tam genişlik oluyor — oranı koruyup
     yüksekliği sınırlıyoruz (4/3'e çevirmek dikey görsellerde
     kenarlarda büyük boşluk bırakıyordu). */
  @media (max-width: 600px) {
    .news-img { max-height: 440px; }
  }
  /* Görsellerin %73'ü zaten 3:4 dikey, kutuyu tam dolduruyor.
     Yatay olanlarda bulanık leke yerine düz koyu panel kalıyor. */
  .news-img-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #141814 0%, #0a0d0a 100%);
  }
  /* Asıl fotoğraf: kırpılmadan, ortalanmış şekilde tamamı görünür */
  .news-img-fg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  .news-body {
    padding: 1.5rem 1.6rem 1.8rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
    flex: 1;
  }

  .news-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: .8rem;
  }
  .news-tag {
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--green-bright);
  }
  .news-date {
    font-size: .72rem;
    font-weight: 600;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .news-body h2 {
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1.35;
    color: var(--text);
    /* Kart yükseklikleri satır içinde tutarlı kalsın */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Özet: en fazla 4 satır — kartlar artık uzayıp boşluk bırakmıyor */
  .news-body p {
    font-size: .875rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-more {
    font-size: .8rem;
    font-weight: 700;
    color: var(--green-bright);
    letter-spacing: .3px;
    transition: color .2s;
  }
  .news-card:hover .news-more { color: #fff; }

  /* ── Boş durum ── */
  .empty-state {
    padding: 6rem 8%;
    text-align: center;
    color: var(--text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .btn-primary {
    background: var(--green);
    color: #fff;
    padding: .7rem 1.6rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: .875rem;
    text-decoration: none;
    transition: background .2s;
  }
  .btn-primary:hover { background: var(--green-mid); }
</style>
